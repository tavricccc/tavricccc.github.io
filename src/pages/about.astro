---
import Layout from '../layouts/BlogPost.astro';
import GoldenSpiral from '../components/GoldenSpiral.astro';
import MeteorShower from '../components/MeteorShower.astro';
import TerminalQuote from '../components/TerminalQuote.astro';

const nowText =
	'Now: Preparing for an internship at a research institute, while building an intelligent hotel management system on the side.';
---

<Layout
	title="About Me - Dan Arnoux (符笙)"
	description="Learn more about DanArnoux (符笙), an energy engineering student from China passionate about practical engineering, clear reasoning, and building reproducible systems."
	pubDate={new Date('Feb 10 2026')}
	metaMode="page"
	heroImage="https://img.danarnoux.com/misc/about-image.webp"
	profileImage="/image/tavricccc.jpg"
>
	<Fragment slot="background">
		<GoldenSpiral />
		<MeteorShower density={1.8} heightVh={60} />
	</Fragment>
	<div class="mx-auto max-w-3xl">
		<p>
			I am DanArnoux (符笙), an energy engineering student from China. I care about practical
			engineering, clear reasoning, and building systems that can be explained and reproduced.
			This blog is my long-term notebook for experiments, tools, and technical decisions.
		</p>

		<h2>Focus</h2>
		<ul>
			<li>Electrochemistry and materials aging: CV / EIS / ECSA analysis, battery degradation, and characterization</li>
			<li>Simulation and modeling: battery-oriented FEM studies, Simulink models, and reproducible workflows</li>
			<li>
				AI and applied systems: Stable Diffusion, LLM-assisted tooling, and
				<a href="https://creatinf.com/" target="_blank" rel="noreferrer">CreatInf</a>
			</li>
		</ul>

		<h2>Now</h2>
		<div class="mx-auto max-w-2xl text-left">
			<TerminalQuote text={nowText} once={true} fixedHeight={false} />
		</div>
	</div>
</Layout>
