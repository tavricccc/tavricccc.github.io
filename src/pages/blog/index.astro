---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import MeteorShower from '../../components/MeteorShower.astro';
import MobileDrawer from '../../components/MobileDrawer.astro';
import PageHeading from '../../components/PageHeading.astro';
import Pagination from '../../components/Pagination.astro';
import PostCard from '../../components/PostCard.astro';
import { SITE_TITLE } from '../../consts';
import { isPublishedPost } from '../../utils/content';

const BASE = import.meta.env.BASE_URL;

// Determine view from pathname
const pathname = Astro.url.pathname;
const isImportant = pathname.endsWith('/important') || pathname === `${BASE}blog/important`;
const isArchive = pathname.endsWith('/archive') || pathname === `${BASE}blog/archive`;

// Get all posts
const allPosts = (await getCollection('blog')).filter(isPublishedPost);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Filter important posts (where important === true), sorted by importantOrder
const importantPosts = allPosts
	.filter((post) => post.data.important === true)
	.sort((a, b) => (b.data.importantOrder || 0) - (a.data.importantOrder || 0));

// Pagination for Latest view
const PAGE_SIZE = 6;
const paginatedPosts = posts.slice(0, PAGE_SIZE);
const lastPage = Math.max(1, Math.ceil(posts.length / PAGE_SIZE));

// Group posts by year and month for archive view
const postsByYearMonth: Record<string, Record<string, typeof posts>> = {};
const monthNames = ['January', 'February', 'March', 'April', 'May', 'June',
                     'July', 'August', 'September', 'October', 'November', 'December'];

posts.forEach((post) => {
	const date = post.data.pubDate;
	const year = date.getFullYear().toString();
	const month = date.getMonth().toString();

	if (!postsByYearMonth[year]) {
		postsByYearMonth[year] = {};
	}
	if (!postsByYearMonth[year][month]) {
		postsByYearMonth[year][month] = [];
	}
	postsByYearMonth[year][month].push(post);
});

// Determine active view and posts to show
let displayPosts: typeof posts = [];
let showPagination = false;
let archiveData: { year: string; months: { name: string; posts: typeof posts }[] }[] | null = null;

if (isImportant) {
	displayPosts = importantPosts;
} else if (isArchive) {
	archiveData = Object.entries(postsByYearMonth)
		.sort(([a], [b]) => parseInt(b) - parseInt(a))
		.map(([year, months]) => ({
			year,
			months: Object.entries(months)
				.sort(([a], [b]) => parseInt(b) - parseInt(a))
				.map(([month, monthPosts]) => ({
					name: monthNames[parseInt(month)],
					posts: monthPosts,
				})),
		}));
} else {
	// Default to Latest
	displayPosts = paginatedPosts;
	showPagination = true;
}

// View URLs
const importantUrl = `${BASE}blog/important/`;
const latestUrl = `${BASE}blog/`;
const archiveUrl = `${BASE}blog/archive/`;

// Determine current view for active state
const currentView = isImportant ? 'important' : isArchive ? 'archive' : 'latest';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Articles | ${SITE_TITLE} - Technical Tutorials & Engineering Guides`} description="Browse all articles on this blog. Find technical tutorials, engineering guides, research notes, and programming tips." />
	</head>
	<body>
		<MeteorShower density={0.4} heightVh={40} />
		<Header />
		<MobileDrawer />
		<main class="page-shell page-fade-in py-10 md:py-14" transition:name="page-main" transition:animate="fade">
			<section class="mx-auto max-w-4xl">
				<PageHeading eyebrow="Writing" title="Articles" subtitle="All of my articles.">
					<!-- Segmented Control with 3 options -->
					<div slot="actions">
					<div
						class="view-toggle inline-flex items-center rounded-2xl border border-zinc-200/80 bg-white/75 p-1 shadow-[0_8px_30px_rgba(15,23,42,0.06)] backdrop-blur-md dark:border-zinc-700/80 dark:bg-zinc-900/70"
						role="tablist"
						aria-label="Articles view switch"
					>
						<a
							href={importantUrl}
							class:list={[
								'apple-float-chip relative inline-flex items-center justify-center rounded-xl px-2 py-2 text-sm font-medium transition-all duration-200 md:px-3 md:gap-2',
								currentView === 'important'
									? 'bg-zinc-900/6 text-zinc-900 shadow-[0_6px_18px_rgba(15,23,42,0.08)] dark:bg-white/10 dark:text-white'
									: 'text-zinc-500 hover:text-zinc-700 dark:text-zinc-400 dark:hover:text-zinc-200',
							]}
							role="tab"
							aria-selected={currentView === 'important'}
						>
							<span class="apple-float-label">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
								</svg>
								<span class="hidden md:inline">Important</span>
							</span>
						</a>
						<a
							href={latestUrl}
							class:list={[
								'apple-float-chip relative inline-flex items-center justify-center rounded-xl px-2 py-2 text-sm font-medium transition-all duration-200 md:px-3 md:gap-2',
								currentView === 'latest'
									? 'bg-zinc-900/6 text-zinc-900 shadow-[0_6px_18px_rgba(15,23,42,0.08)] dark:bg-white/10 dark:text-white'
									: 'text-zinc-500 hover:text-zinc-700 dark:text-zinc-400 dark:hover:text-zinc-200',
							]}
							role="tab"
							aria-selected={currentView === 'latest'}
						>
							<span class="apple-float-label">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
								</svg>
								<span class="hidden md:inline">Latest</span>
							</span>
						</a>
						<a
							href={archiveUrl}
							class:list={[
								'apple-float-chip relative inline-flex items-center justify-center rounded-xl px-2 py-2 text-sm font-medium transition-all duration-200 md:px-3 md:gap-2',
								currentView === 'archive'
									? 'bg-zinc-900/6 text-zinc-900 shadow-[0_6px_18px_rgba(15,23,42,0.08)] dark:bg-white/10 dark:text-white'
									: 'text-zinc-500 hover:text-zinc-700 dark:text-zinc-400 dark:hover:text-zinc-200',
							]}
							role="tab"
							aria-selected={currentView === 'archive'}
						>
							<span class="apple-float-label">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
								</svg>
								<span class="hidden md:inline">Archive</span>
							</span>
						</a>
					</div>
				</div>
				</PageHeading>

				<div class="mt-8 min-h-[24rem]">
					<!-- Important View -->
					{currentView === 'important' && (
						<div role="tabpanel">
							{displayPosts.length > 0 ? (
								<ul class="grid gap-4">
									{displayPosts.map((post, idx) => (
										<li class="relative" data-reveal style={`--reveal-delay: ${Math.min(idx * 60, 180)}ms`}>
											<PostCard post={post} base={BASE} maxMobile={3} maxDesktop={null} reloadOnNavigate={true} />
										</li>
									))}
								</ul>
							) : (
								<div class="flex h-32 flex-col items-center justify-center text-zinc-500 dark:text-zinc-400">
									<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mb-2 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
										<path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
									</svg>
									<p>No important posts yet</p>
								</div>
							)}
						</div>
					)}

					<!-- Latest View (default) -->
					{currentView === 'latest' && (
						<div role="tabpanel">
							<ul class="grid gap-4">
								{displayPosts.map((post, idx) => (
									<li class="relative" data-reveal style={`--reveal-delay: ${Math.min(idx * 60, 180)}ms`}>
										<PostCard post={post} base={BASE} maxMobile={3} maxDesktop={null} reloadOnNavigate={true} />
									</li>
								))}
							</ul>
							{showPagination && (
								<div class="mt-8">
									<Pagination currentPage={1} lastPage={lastPage} basePath={`${BASE}blog`} />
								</div>
							)}
						</div>
					)}

					<!-- Archive View -->
					{currentView === 'archive' && (
						<div role="tabpanel" class="pb-8">
							{archiveData && archiveData.map((yearData, yearIdx) => (
								<div class="archive-year" style={`animation-delay: ${yearIdx * 80}ms`}>
									<h2 class="mt-8 first:mt-0 text-2xl font-bold text-zinc-800 dark:text-zinc-200">{yearData.year}</h2>
									{yearData.months.map((monthData, monthIdx) => (
										<div class="archive-month" style={`animation-delay: ${(yearIdx * 80) + (monthIdx * 40) + 40}ms`}>
											<h3 class="mt-6 first:mt-4 text-lg font-semibold text-zinc-600 dark:text-zinc-400">
												{monthData.name}
											</h3>
											<ul class="mt-3 space-y-3 border-l-2 border-zinc-200 dark:border-zinc-700 pl-4">
												{monthData.posts.map((post, postIdx) => (
													<li class="relative" style={`animation-delay: ${(yearIdx * 80) + (monthIdx * 40) + (postIdx * 20) + 80}ms`}>
														<span class="absolute -left-[21px] top-2 h-2 w-2 rounded-full bg-zinc-300 dark:bg-zinc-600"></span>
														<a
															href={`${BASE}blog/${post.id}/`}
															class="block rounded-xl p-3 text-zinc-700 transition-all duration-200 hover:bg-zinc-100/85 hover:translate-x-0.5 dark:text-zinc-300 dark:hover:bg-zinc-800/85"
														>
															<span class="font-medium">{post.data.title}</span>
															<p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400 line-clamp-1">{post.data.description}</p>
														</a>
													</li>
												))}
											</ul>
										</div>
									))}
								</div>
							))}
						</div>
					)}
				</div>
			</section>
		</main>
		<Footer />

		<style is:global>
			@media (prefers-reduced-motion: reduce) {
				.card-enter,
				.archive-year,
				.archive-month {
					transition: none !important;
					animation: none !important;
					transform: none !important;
					opacity: 1 !important;
				}
			}
		</style>
	</body>
</html>
