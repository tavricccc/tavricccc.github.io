---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import MeteorShower from '../../components/MeteorShower.astro';
import MobileDrawer from '../../components/MobileDrawer.astro';
import PageHeading from '../../components/PageHeading.astro';
import { SITE_TITLE } from '../../consts';
import { isPublishedPost } from '../../utils/content';

const BASE = import.meta.env.BASE_URL;

// Get all posts
const allPosts = (await getCollection('blog')).filter(isPublishedPost);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Group posts by year and month for archive view
const postsByYearMonth: Record<string, Record<string, typeof posts>> = {};
const monthNames = ['January', 'February', 'March', 'April', 'May', 'June',
	'July', 'August', 'September', 'October', 'November', 'December'] as const;

posts.forEach((post) => {
	const date = post.data.pubDate;
	const year = date.getFullYear().toString();
	const month = date.getMonth().toString();

	if (!postsByYearMonth[year]) {
		postsByYearMonth[year] = {};
	}
	if (!postsByYearMonth[year][month]) {
		postsByYearMonth[year][month] = [];
	}
	postsByYearMonth[year][month].push(post);
});

const archiveData = Object.entries(postsByYearMonth)
	.sort(([a], [b]) => parseInt(b) - parseInt(a))
	.map(([year, months]) => ({
		year,
		months: Object.entries(months)
			.sort(([a], [b]) => parseInt(b) - parseInt(a))
			.map(([month, monthPosts]) => ({
				name: monthNames[parseInt(month)],
				posts: monthPosts,
			})),
	}));

// View URLs
const latestUrl = `${BASE}blog/`;
const importantUrl = `${BASE}blog/important/`;
const currentView = 'archive';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Articles Archive | ${SITE_TITLE} - All Posts by Year & Month`} description="Browse all articles organized by year and month. Explore the complete archive of articles, tutorials, and technical notes." />
	</head>
	<body>
		<MeteorShower density={0.4} heightVh={40} />
		<Header />
		<MobileDrawer />
		<main class="page-shell page-fade-in py-10 md:py-14" transition:name="page-main" transition:animate="fade">
			<section class="mx-auto max-w-4xl">
				<PageHeading eyebrow="Writing" title="Articles" subtitle="Browse all posts organized by year and month.">
					<!-- Segmented Control with 3 options -->
					<div
						slot="actions"
						class="view-toggle inline-flex items-center rounded-2xl border border-zinc-200/80 bg-white/75 p-1 shadow-[0_8px_30px_rgba(15,23,42,0.06)] backdrop-blur-md dark:border-zinc-700/80 dark:bg-zinc-900/70"
						role="tablist"
						aria-label="Articles view switch"
					>
						<a
							href={importantUrl}
							class:list={[
								'apple-float-chip relative inline-flex items-center justify-center rounded-xl px-2 py-2 text-sm font-medium transition-all duration-200 md:px-3 md:gap-2',
								currentView === 'important'
									? 'bg-zinc-900/6 text-zinc-900 shadow-[0_6px_18px_rgba(15,23,42,0.08)] dark:bg-white/10 dark:text-white'
									: 'text-zinc-500 hover:text-zinc-700 dark:text-zinc-400 dark:hover:text-zinc-200',
							]}
							role="tab"
							aria-selected={currentView === 'important'}
						>
							<span class="apple-float-label">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
								</svg>
								<span class="hidden md:inline">Important</span>
							</span>
						</a>
						<a
							href={latestUrl}
							class:list={[
								'apple-float-chip relative inline-flex items-center justify-center rounded-xl px-2 py-2 text-sm font-medium transition-all duration-200 md:px-3 md:gap-2',
								currentView === 'latest'
									? 'bg-zinc-900/6 text-zinc-900 shadow-[0_6px_18px_rgba(15,23,42,0.08)] dark:bg-white/10 dark:text-white'
									: 'text-zinc-500 hover:text-zinc-700 dark:text-zinc-400 dark:hover:text-zinc-200',
							]}
							role="tab"
							aria-selected={currentView === 'latest'}
						>
							<span class="apple-float-label">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
								</svg>
								<span class="hidden md:inline">Latest</span>
							</span>
						</a>
						<a
							href={`${BASE}blog/archive/`}
							class:list={[
								'apple-float-chip relative inline-flex items-center justify-center rounded-xl px-2 py-2 text-sm font-medium transition-all duration-200 md:px-3 md:gap-2',
								currentView === 'archive'
									? 'bg-zinc-900/6 text-zinc-900 shadow-[0_6px_18px_rgba(15,23,42,0.08)] dark:bg-white/10 dark:text-white'
									: 'text-zinc-500 hover:text-zinc-700 dark:text-zinc-400 dark:hover:text-zinc-200',
							]}
							role="tab"
							aria-selected={currentView === 'archive'}
						>
							<span class="apple-float-label">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
								</svg>
								<span class="hidden md:inline">Archive</span>
							</span>
						</a>
					</div>
				</PageHeading>

				<div class="mt-8 min-h-[24rem]">
					<div role="tabpanel" class="pb-8">
						{archiveData?.map((yearData, yearIdx) => {
							const yearPosts = yearData.months.reduce((sum, m) => sum + m.posts.length, 0);
							return (
							<section class="archive-year" style={`animation-delay: ${yearIdx * 80}ms`}>
								<div class="mt-10 flex items-baseline gap-3 first:mt-0">
									<h2 class="font-sans text-3xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">{yearData.year}</h2>
									<span class="text-sm font-medium text-zinc-400 dark:text-zinc-500">{yearPosts} {yearPosts === 1 ? 'post' : 'posts'}</span>
									<span class="h-px flex-1 bg-gradient-to-r from-zinc-200 to-transparent dark:from-zinc-800"></span>
								</div>
								{yearData.months.map((monthData, monthIdx) => (
									<div class="archive-month mt-6" style={`animation-delay: ${(yearIdx * 80) + (monthIdx * 40) + 40}ms`}>
										<h3 class="mb-1 flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.18em] text-zinc-400 dark:text-zinc-500">
											<span class="h-1.5 w-1.5 rounded-full bg-[rgb(180,126,36)] dark:bg-[rgb(226,190,110)]"></span>
											{monthData.name}
										</h3>
										<ul class="space-y-1.5 border-l-2 border-zinc-200 pl-4 dark:border-zinc-800">
											{monthData.posts.map((post, postIdx) => (
												<li class="archive-entry relative" style={`animation-delay: ${(yearIdx * 80) + (monthIdx * 40) + (postIdx * 20) + 80}ms`}>
													<span class="archive-dot absolute -left-[21px] top-[1.15rem]"></span>
													<a
														href={`${BASE}blog/${post.id}/`}
														class="group block rounded-xl border border-transparent p-3 transition-all duration-200 hover:translate-x-0.5 hover:border-zinc-200 hover:bg-white/70 hover:shadow-sm dark:hover:border-zinc-800 dark:hover:bg-zinc-900/60"
													>
														<span class="font-medium text-zinc-800 transition-colors group-hover:text-zinc-950 dark:text-zinc-200 dark:group-hover:text-zinc-50">{post.data.title}</span>
														<p class="mt-1 text-sm text-zinc-500 line-clamp-1 dark:text-zinc-400">{post.data.description}</p>
													</a>
												</li>
											))}
										</ul>
									</div>
								))}
							</section>
							);
						})}
					</div>
				</div>
			</section>
		</main>
		<Footer />

		<style is:global>
			/* Timeline node: a hollow gold ring that fills as you hover the entry. */
			.archive-dot {
				width: 9px;
				height: 9px;
				border-radius: 9999px;
				background: rgb(250 250 250);
				border: 2px solid rgba(180, 126, 36, 0.55);
				transition: background-color 180ms ease, border-color 180ms ease, transform 200ms cubic-bezier(0.22, 1, 0.36, 1);
			}

			html.dark .archive-dot {
				background: rgb(9 9 11);
				border-color: rgba(226, 190, 110, 0.5);
			}

			.archive-entry:hover .archive-dot {
				background: rgb(180 126 36);
				border-color: rgb(180 126 36);
				transform: scale(1.18);
			}

			html.dark .archive-entry:hover .archive-dot {
				background: rgb(226 190 110);
				border-color: rgb(226 190 110);
			}

			@media (prefers-reduced-motion: reduce) {
				.archive-year,
				.archive-month {
					transition: none !important;
					animation: none !important;
					transform: none !important;
					opacity: 1 !important;
				}

				.archive-dot,
				.archive-entry:hover .archive-dot {
					transition: none !important;
				}
			}
		</style>
	</body>
</html>
