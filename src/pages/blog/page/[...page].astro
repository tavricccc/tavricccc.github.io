---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import MobileDrawer from '../../../components/MobileDrawer.astro';
import Pagination from '../../../components/Pagination.astro';
import PostCard from '../../../components/PostCard.astro';
import { SITE_TITLE } from '../../../consts';

const BASE_DESCRIPTION = 'Browse all articles on this blog. Find technical tutorials, engineering guides, research notes, and programming tips.';

const BASE = import.meta.env.BASE_URL;

export async function getStaticPaths({ paginate }) {
	// Keep page size colocated with route generation so pagination stays deterministic at build time.
	const PAGE_SIZE = 6;
	const posts = (await getCollection('blog')).sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);

	// Page 1 is intentionally handled by /blog/ to avoid duplicate first-page routes.
	return paginate(posts, { pageSize: PAGE_SIZE }).filter(
		(entry) => entry.props.page.currentPage > 1,
	);
}

interface Props {
	page: {
		currentPage: number;
		lastPage: number;
		data: any[];
	};
}

const { page } = Astro.props as Props;

// Generate unique description for each page to avoid SEO penalties
const pageDescription = page.currentPage === 1
	? BASE_DESCRIPTION
	: `Browse page ${page.currentPage} of ${page.lastPage}. ${BASE_DESCRIPTION}`;

const importantUrl = `${BASE}blog/important/`;
const latestUrl = `${BASE}blog/`;
const archiveUrl = `${BASE}blog/archive/`;
const currentView = 'latest';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog Page ${page.currentPage} | ${SITE_TITLE} - All Articles`} description={pageDescription} />
		<meta name="robots" content="noindex,follow" />
	</head>
	<body>
		<Header />
		<MobileDrawer />
		<main class="page-shell page-fade-in py-10 md:py-14" transition:name="page-main" transition:animate="fade">
			<section class="section-enter mx-auto max-w-4xl">
				<div class="flex items-center justify-between">
					<h1 class="font-sans text-3xl font-semibold leading-tight tracking-tight text-zinc-900 dark:text-zinc-100 md:text-4xl">
						Blog
					</h1>
					<div
						class="view-toggle inline-flex items-center rounded-2xl border border-zinc-200/80 bg-white/75 p-1 shadow-[0_8px_30px_rgba(15,23,42,0.06)] backdrop-blur-md dark:border-zinc-700/80 dark:bg-zinc-900/70"
						role="tablist"
						aria-label="Blog view switch"
					>
						<a
							href={importantUrl}
							class:list={[
								'apple-float-chip relative inline-flex items-center justify-center rounded-xl px-2 py-2 text-sm font-medium transition-all duration-200 md:px-3 md:gap-2',
								currentView === 'important'
									? 'bg-zinc-900/6 text-zinc-900 shadow-[0_6px_18px_rgba(15,23,42,0.08)] dark:bg-white/10 dark:text-white'
									: 'text-zinc-500 hover:text-zinc-700 dark:text-zinc-400 dark:hover:text-zinc-200',
							]}
							role="tab"
							aria-selected={currentView === 'important'}
						>
							<span class="apple-float-label">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
								</svg>
								<span class="hidden md:inline">Important</span>
							</span>
						</a>
						<a
							href={latestUrl}
							class:list={[
								'apple-float-chip relative inline-flex items-center justify-center rounded-xl px-2 py-2 text-sm font-medium transition-all duration-200 md:px-3 md:gap-2',
								currentView === 'latest'
									? 'bg-zinc-900/6 text-zinc-900 shadow-[0_6px_18px_rgba(15,23,42,0.08)] dark:bg-white/10 dark:text-white'
									: 'text-zinc-500 hover:text-zinc-700 dark:text-zinc-400 dark:hover:text-zinc-200',
							]}
							role="tab"
							aria-selected={currentView === 'latest'}
						>
							<span class="apple-float-label">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
								</svg>
								<span class="hidden md:inline">Latest</span>
							</span>
						</a>
						<a
							href={archiveUrl}
							class:list={[
								'apple-float-chip relative inline-flex items-center justify-center rounded-xl px-2 py-2 text-sm font-medium transition-all duration-200 md:px-3 md:gap-2',
								currentView === 'archive'
									? 'bg-zinc-900/6 text-zinc-900 shadow-[0_6px_18px_rgba(15,23,42,0.08)] dark:bg-white/10 dark:text-white'
									: 'text-zinc-500 hover:text-zinc-700 dark:text-zinc-400 dark:hover:text-zinc-200',
							]}
							role="tab"
							aria-selected={currentView === 'archive'}
						>
							<span class="apple-float-label">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
								</svg>
								<span class="hidden md:inline">Archive</span>
							</span>
						</a>
					</div>
				</div>
				<p class="mt-2 font-sans text-zinc-500 dark:text-zinc-400">Research notes, engineering logs, and technical essays.</p>

				<ul class="mt-8 grid gap-4">
					{
						page.data.map((post, idx) => (
							<li class="card-enter relative" style={`animation-delay: ${90 + idx * 40}ms`}>
								<PostCard post={post} base={BASE} maxMobile={3} maxDesktop={null} reloadOnNavigate={true} />
							</li>
						))
					}
				</ul>
				<div>
					<Pagination currentPage={page.currentPage} lastPage={page.lastPage} basePath={`${BASE}blog`} />
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
