---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import MobileDrawer from '../components/MobileDrawer.astro';
import TocSidebar from '../components/TocSidebar.astro';
import TocDrawer from '../components/TocDrawer.astro';
import { getTagSlug } from '../utils/tags';

/* Blog post layout coordinates desktop TOC, mobile drawer TOC, and route-transition-safe scripts. */
type Props = CollectionEntry<'blog'>['data'] & {
	profileImage?: string;
	headings?: { depth: number; slug: string; text: string }[];
	rawBody?: string;
	slug?: string;
	metaMode?: 'article' | 'page';
	languageSwitch?: {
		href: string;
		label: string;
	};
	relatedPosts?: CollectionEntry<'blog'>[];
	relatedPostsLang?: 'cn' | 'en';
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	profileImage,
	tags = [],
	headings = [],
	rawBody = '',
	metaMode = 'article',
	languageSwitch,
	relatedPosts = [],
	relatedPostsLang = 'en',
} = Astro.props;

const BASE = import.meta.env.BASE_URL;
const withBase = (path: string) => {
	// Keep public asset references resilient across root and subpath deployments.
	if (!path) return path;
	if (path.startsWith('http://') || path.startsWith('https://')) return path;
	if (path.startsWith(BASE)) return path;
	return `${BASE}${path.replace(/^\/+/, '')}`;
};

const tocItems = headings.filter((h) => h.depth === 2 || h.depth === 3 || h.depth === 4);
const hasToc = tocItems.length > 0;
// Reading time is character-based to stay language-neutral for mixed CN/EN content.
const chars = rawBody.replace(/\s+/g, '').length;
const minutes = Math.max(1, Math.ceil(chars / 950));
const charsLabel = chars.toLocaleString('en-US');
---

<html lang="en">
	<head>
		<BaseHead title={`${title} | Tavric's Blog`} description={description} />
	</head>
	<body>
		<!-- Optional decorative background layer (e.g. the About page meteor shower). -->
		<slot name="background" />
		<!-- Scroll-driven reading progress; hidden automatically where unsupported. -->
		<div class="reading-progress" aria-hidden="true"></div>
		<Header showTocButton={hasToc} />
		<MobileDrawer />
		<TocDrawer headings={tocItems} />

		<!-- Page fade is CSS-driven so route changes remain smooth even when shared-element transitions are bypassed. -->
		<main class="blog-post-page page-fade-in min-h-screen min-w-0 w-full py-10 md:py-14" transition:name="page-main" transition:animate="fade">
			<div class:list={[
				'mx-auto min-w-0 px-4 sm:px-6 lg:px-8',
				metaMode === 'page' ? 'max-w-4xl' : 'max-w-7xl',
			]}>
				<div class:list={[
					'mt-10 min-w-0',
					metaMode === 'page'
						? 'mx-auto max-w-3xl'
						: 'md:grid md:grid-cols-[240px_minmax(0,1fr)] md:gap-10 lg:grid-cols-[280px_minmax(0,820px)_minmax(0,1fr)] lg:gap-x-10',
				]}>
					<aside class:list={[
						metaMode === 'page' ? 'hidden' : 'hidden md:block',
					]} data-toc-fade-wrap>
						<div class="sticky top-24 self-start">
							<div class="relative">
								<div class="toc-scroll max-h-[calc(100vh-7.5rem)] overflow-auto pr-2" data-toc-scroll="sidebar">
								{
									hasToc ? (
										<TocSidebar headings={tocItems} />
									) : (
										// Placeholder keeps first paint geometry stable when a post has no headings.
										<div
											class="min-h-[220px] rounded-2xl border border-transparent bg-transparent"
											aria-hidden="true"
										></div>
									)
								}
							</div>
							<div
								data-toc-fade="top"
								class="toc-fade toc-fade-top pointer-events-none absolute inset-x-0 top-0 h-8 opacity-0"
							></div>
							<div
								data-toc-fade="bottom"
								class="toc-fade toc-fade-bottom pointer-events-none absolute inset-x-0 bottom-0 h-8 opacity-0"
							></div>
						</div>
						</div>
					</aside>

					<main class:list={[
						'min-w-0',
						metaMode !== 'page' && 'lg:col-start-2',
					]}>
						<header class="mb-10 min-w-0 border-b border-zinc-200 pb-6 dark:border-zinc-700">
							{
								metaMode === 'page' ? (
									<div class="mb-1 flex items-center gap-3 text-[11px] font-medium uppercase tracking-[0.14em] text-zinc-400 dark:text-zinc-500">
										<span class="h-px w-10 bg-zinc-200 dark:bg-zinc-700"></span>
										<span class="inline-flex items-center gap-2">
											<span class="inline-flex h-1.5 w-1.5 rounded-full bg-zinc-300 dark:bg-zinc-600"></span>
											<FormattedDate date={pubDate} />
										</span>
									</div>
								) : (
									<p class="m-0 text-sm text-zinc-500 dark:text-zinc-400">
										<FormattedDate date={pubDate} />
										<span class="mx-1.5">&middot;</span>
										<span>{charsLabel} chars</span>
										<span class="mx-1.5">&middot;</span>
										<span>{minutes} min</span>
										{updatedDate && (
											<span class="ml-3 inline-block italic">
												Updated <FormattedDate date={updatedDate} />
											</span>
										)}
									</p>
								)
							}

							<div class="mt-3 flex min-w-0 items-start justify-between gap-4">
								<h1
									class="min-w-0 flex-1 font-sans text-3xl font-semibold leading-tight tracking-tight text-zinc-900 [overflow-wrap:anywhere] dark:text-zinc-100 md:text-4xl"
									transition:animate="fade"
								>
									{title}
								</h1>

								{profileImage && (
									<img
										src={withBase(profileImage)}
										alt={`${title} profile`}
										class="h-14 w-14 shrink-0 rounded-full border border-zinc-200 object-cover dark:border-zinc-700 md:h-16 md:w-16"
										loading="lazy"
									/>
								)}
							</div>

							<p class="mt-3 font-body text-zinc-600 dark:text-zinc-300">{description}</p>

							{languageSwitch && (
								<div class="mt-4">
									<a
										href={languageSwitch.href}
										class="inline-flex items-center rounded-lg border border-zinc-200 px-3 py-1.5 text-sm font-medium text-zinc-700 no-underline transition-colors hover:border-zinc-300 hover:text-zinc-900 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-zinc-500 dark:hover:text-zinc-100"
										transition:name="lang-switch"
										transition:animate="none"
										data-astro-reload
									>
										{languageSwitch.label}
									</a>
								</div>
							)}

							{tags.length > 0 && (
								<div class="mt-4 flex flex-wrap gap-2">
									{tags.map((tag) => (
										<a
											href={`${BASE}tags/${encodeURIComponent(getTagSlug(tag))}/`}
										class="inline-flex items-center rounded-md border border-zinc-300/90 bg-zinc-50/96 px-2.5 py-1 text-xs font-medium text-zinc-700 no-underline transition-colors duration-150 ease-out hover:border-zinc-400 hover:bg-white hover:text-zinc-900 dark:border-zinc-700/90 dark:bg-zinc-900/96 dark:text-zinc-300 dark:hover:border-zinc-500 dark:hover:bg-zinc-800 dark:hover:text-zinc-100"
										>
											#{tag}
										</a>
									))}
								</div>
							)}
						</header>

						<article class="section-enter min-w-0 w-full max-w-none">
							{
								heroImage &&
									(typeof heroImage === 'string' ? (
										<div class="mb-8 aspect-[16/9] overflow-hidden rounded-2xl border border-zinc-200 bg-white dark:border-zinc-700 dark:bg-zinc-900">
											<img src={withBase(heroImage)} alt={title} class="h-full w-full object-cover" loading="lazy" />
										</div>
									) : (
										<div class="mb-8 overflow-hidden rounded-2xl border border-zinc-200 bg-white dark:border-zinc-700 dark:bg-zinc-900">
											<Image width={1200} height={620} src={heroImage} alt="" class="h-auto w-full" />
										</div>
									))
							}

							<div class="markdown-prose min-w-0">
								<slot />
							</div>
						</article>

						<!-- Related Posts Section -->
						{
							relatedPosts.length > 0 && (
								<section class="mt-12 border-t border-zinc-200 pt-10 dark:border-zinc-700">
									<h2 class="mb-6 font-sans text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">
										{relatedPostsLang === 'cn' ? '相关推荐' : 'Related Posts'}
									</h2>
									<div class="grid gap-4 sm:grid-cols-2">
										{relatedPosts.map((relatedPost, relatedIdx) => {
											const postUrl = `${BASE}blog/${relatedPost.id}/`;
											const postTags = (relatedPost.data.tags ?? []).slice(0, 3);
											return (
												<div data-reveal style={`--reveal-delay: ${(relatedIdx % 2) * 80}ms`}>
												<a
													href={postUrl}
													class="card-spotlight group relative block h-full rounded-xl border border-zinc-200 bg-white p-4 transition-all duration-200 hover:border-zinc-300 hover:shadow-lg hover:-translate-y-0.5 dark:border-zinc-700 dark:bg-zinc-800/50 dark:hover:border-zinc-600 dark:hover:bg-zinc-800"
												>
													<h3 class="font-semibold text-zinc-900 transition-colors group-hover:text-orange-600 dark:text-zinc-100 dark:group-hover:text-orange-400">
														{relatedPost.data.title}
													</h3>
													<p class="mt-2 line-clamp-2 text-sm text-zinc-600 dark:text-zinc-400">
														{relatedPost.data.description}
													</p>
													<div class="mt-3 flex items-end justify-between gap-3">
														{postTags.length > 0 ? (
														<div class="flex flex-wrap gap-1.5">
															{postTags.map((tag) => (
																<span class="rounded-md bg-zinc-100 px-2 py-0.5 text-xs font-medium text-zinc-600 dark:bg-zinc-700 dark:text-zinc-300">
																	#{tag}
																</span>
															))}
														</div>
														) : (
														<span></span>
														)}
													</div>
												</a>
												</div>
											);
										})}
									</div>
								</section>
							)
						}
					</main>

					<div class="hidden lg:block" aria-hidden="true"></div>
				</div>
			</div>
		</main>

		<Footer />

		<button type="button" class="back-to-top" data-back-to-top aria-label="Back to top">
			<svg class="back-to-top-ring" viewBox="0 0 48 48" aria-hidden="true">
				<circle class="back-to-top-track" cx="24" cy="24" r="21" />
				<circle class="back-to-top-progress" cx="24" cy="24" r="21" data-back-to-top-progress />
			</svg>
			<svg class="back-to-top-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
				<path d="M12 19V5" stroke-linecap="round" />
				<path d="m5 12 7-7 7 7" stroke-linecap="round" stroke-linejoin="round" />
			</svg>
		</button>

		<div
			id="img-lightbox"
			class="fixed inset-0 z-[999] hidden items-center justify-center overflow-auto bg-black/65 p-4 backdrop-blur-md md:p-8 dark:bg-black/75"
			aria-hidden="true"
		>
			<button
				id="img-lightbox-close"
				type="button"
				class="fixed right-4 top-4 inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/25 bg-black/35 text-white transition-colors hover:bg-black/55"
				aria-label="Close image preview"
				data-lightbox-close
			>
				<svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true">
					<path d="M6.7 5.3a1 1 0 0 0-1.4 1.4L10.6 12l-5.3 5.3a1 1 0 1 0 1.4 1.4l5.3-5.3 5.3 5.3a1 1 0 1 0 1.4-1.4L13.4 12l5.3-5.3a1 1 0 0 0-1.4-1.4L12 10.6 6.7 5.3Z" />
				</svg>
			</button>
			<figure class="m-0 flex max-w-full flex-col items-center gap-3">
				<img
					id="img-lightbox-target"
					src=""
					alt=""
					class="mx-auto block h-auto max-h-[88dvh] max-w-[92vw] rounded-xl object-contain shadow-2xl"
				/>
				<figcaption
					id="img-lightbox-caption"
					class="max-w-[78vw] text-center font-sans text-[13px] leading-6 text-zinc-300 empty:hidden"
				></figcaption>
			</figure>
		</div>

		<style is:global>
			.markdown-prose :is(h2, h3, h4) {
				scroll-margin-top: 7rem;
			}
		</style>

		<script is:inline>
			const scrollToTopIfNoHash = () => {
				// Manual restoration prevents stale scroll positions when View Transitions swap pages.
				try {
					if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
				} catch {}
				if (!window.location.hash) {
					requestAnimationFrame(() => requestAnimationFrame(() => window.scrollTo(0, 0)));
				}
			};

			const initTocActiveState = () => {
				// Clean and re-bind because Astro swaps DOM without a full page refresh.
				if (typeof window.__tocCleanup === 'function') {
					window.__tocCleanup();
					window.__tocCleanup = null;
				}

				// Get ALL TOC links from both sidebar and drawer (not scoped to viewport).
				const links = Array.from(document.querySelectorAll('[data-toc-link]'));
				const headings = Array.from(
					document.querySelectorAll('.markdown-prose h2[id], .markdown-prose h3[id], .markdown-prose h4[id]')
				);

				if (links.length === 0 || headings.length === 0) return;

				const ACTIVE_CLASSES = [
					'bg-zinc-100/55',
					'text-zinc-900',
					'border-zinc-400/90',
					'dark:bg-zinc-800/55',
					'dark:text-zinc-100',
					'dark:border-zinc-500/90',
				];

				// Helper: normalize heading ID for matching (decode URL-encoded IDs).
				const normalizeId = (id) => {
					try {
						return decodeURIComponent(id);
					} catch {
						return id;
					}
				};

				// Map heading id -> all matching TOC links (both sidebar and drawer)
				// Use normalized (decoded) IDs for matching with heading.id
				const linkMap = new Map();
				for (const link of links) {
					const rawId = link.dataset.tocLink || '';
					if (!rawId) continue;
					const id = normalizeId(rawId);
					const group = linkMap.get(id) || [];
					group.push(link);
					linkMap.set(id, group);
				}

				const clearActive = () => {
					for (const link of links) {
						link.classList.remove(...ACTIVE_CLASSES);
						link.removeAttribute('aria-current');
					}
				};

				const isElementVisible = (element) => {
					if (!(element instanceof Element)) return false;
					if (element.getClientRects().length === 0) return false;
					const style = window.getComputedStyle(element);
					return style.display !== 'none' && style.visibility !== 'hidden';
				};

				// Scroll TOC link into view within its container (if container exists).
				const ensureVisibleInToc = (link) => {
					const container = link.closest('[data-toc-scroll]');
					if (!container) return;
					if (!isElementVisible(link) || !isElementVisible(container)) return;
					const cRect = container.getBoundingClientRect();
					const eRect = link.getBoundingClientRect();
					if (eRect.top < cRect.top || eRect.bottom > cRect.bottom) {
						link.scrollIntoView({ block: 'nearest' });
					}
				};

				// Set active state for ALL matching links (sidebar + drawer).
				const setActive = (id) => {
					clearActive();
					if (!id) return;
					const normalizedId = normalizeId(id);
					const group = linkMap.get(normalizedId) || [];
					for (const link of group) {
						link.classList.add(...ACTIVE_CLASSES);
						link.setAttribute('aria-current', 'true');
						ensureVisibleInToc(link);
					}
				};

				// Use IntersectionObserver to detect which heading is currently visible.
				let observer = null;
				let rafId = 0;
				let currentId = '';

				const updateActive = () => {
					if (rafId) cancelAnimationFrame(rafId);
					rafId = requestAnimationFrame(() => {
						// Find the first heading that is in the visible viewport area.
						let newId = '';
						for (const heading of headings) {
							const rect = heading.getBoundingClientRect();
							// Heading is "active" when its top is near the top of viewport.
							if (rect.top <= 140) {
								newId = heading.id;
							}
						}
						// Also check if the first heading is below viewport (edge case).
						if (!newId && headings[0]) {
							const firstRect = headings[0].getBoundingClientRect();
							if (firstRect.top > 140) {
								newId = headings[0].id;
							}
						}
						if (newId && newId !== currentId) {
							currentId = newId;
							setActive(newId);
						}
					});
				};

				const syncVisibleTocActive = () => {
					if (currentId && linkMap.has(normalizeId(currentId))) {
						setActive(currentId);
						return;
					}
					updateActive();
				};

				// Try to use IntersectionObserver first (more accurate).
				try {
					observer = new IntersectionObserver(
						(entries) => {
							// Find the topmost visible heading.
							let topmost = null;
							let topmostTop = Infinity;
							for (const entry of entries) {
								if (entry.isIntersecting && entry.target.getBoundingClientRect().top < topmostTop) {
									topmost = entry.target;
									topmostTop = entry.target.getBoundingClientRect().top;
								}
							}
							if (topmost) {
								const newId = topmost.id;
								if (newId !== currentId) {
									currentId = newId;
									setActive(newId);
								}
							}
						},
						{
							rootMargin: '-140px 0px -60% 0px',
							threshold: 0
						}
					);

					headings.forEach((heading) => {
						if (heading.id) observer.observe(heading);
					});
				} catch (e) {
					// Fallback to scroll listener if IntersectionObserver fails.
					window.addEventListener('scroll', updateActive, { passive: true });
				}

				const onHashChange = () => {
					const hashId = window.location.hash.replace(/^#/, '');
					const id = normalizeId(hashId);
					if (id && linkMap.has(id)) {
						currentId = id;
						setActive(id);
					}
				};

				window.addEventListener('resize', updateActive);
				window.addEventListener('hashchange', onHashChange);
				window.addEventListener('toc:sync-active', syncVisibleTocActive);

				// Set initial active heading based on URL hash or scroll position.
				const rawHashId = window.location.hash.replace(/^#/, '');
				const hashId = normalizeId(rawHashId);
				if (hashId && linkMap.has(hashId)) {
					currentId = hashId;
					setActive(hashId);
				} else if (!observer) {
					// No observer, manually check scroll position.
					updateActive();
				}

				window.__tocCleanup = () => {
					if (rafId) cancelAnimationFrame(rafId);
					if (observer) {
						observer.disconnect();
						observer = null;
					}
					window.removeEventListener('scroll', updateActive);
					window.removeEventListener('resize', updateActive);
					window.removeEventListener('hashchange', onHashChange);
					window.removeEventListener('toc:sync-active', syncVisibleTocActive);
				};
			};

			const initTocScrollFades = () => {
				// Fades are computed from scroll state to hint overflow without extra permanent chrome.
				if (typeof window.__tocFadeCleanup === 'function') {
					window.__tocFadeCleanup();
					window.__tocFadeCleanup = null;
				}

				// Only initialize fade effects for the current viewport's TOC container.
				const isMobile = window.innerWidth < 768;
				const tocContainer = document.querySelector(isMobile ? '[data-toc="drawer"]' : '[data-toc="sidebar"]');
				if (!tocContainer) return;

				const wrap = tocContainer.querySelector('[data-toc-fade-wrap]');
				const wraps = wrap ? [wrap] : [];
				if (wraps.length === 0) return;

				const cleanups = [];
				const updateFns = [];
				const EPS = 1;

				for (const wrap of wraps) {
					const container = wrap.querySelector('[data-toc-scroll]');
					const topFade = wrap.querySelector('[data-toc-fade="top"]');
					const bottomFade = wrap.querySelector('[data-toc-fade="bottom"]');
					if (!container || !topFade || !bottomFade) continue;
					let rafId = 0;

					const applyFadeState = () => {
						rafId = 0;
						const canScroll = container.scrollHeight - container.clientHeight > EPS;
						if (!canScroll) {
							topFade.classList.add('opacity-0');
							topFade.classList.remove('opacity-100');
							bottomFade.classList.add('opacity-0');
							bottomFade.classList.remove('opacity-100');
							return;
						}

						const showTop = container.scrollTop > EPS;
						const showBottom = container.scrollTop + container.clientHeight < container.scrollHeight - EPS;

						topFade.classList.toggle('opacity-100', showTop);
						topFade.classList.toggle('opacity-0', !showTop);
						bottomFade.classList.toggle('opacity-100', showBottom);
						bottomFade.classList.toggle('opacity-0', !showBottom);
					};

					const scheduleFadeUpdate = () => {
						if (rafId) return;
						rafId = requestAnimationFrame(applyFadeState);
					};

					container.addEventListener('scroll', scheduleFadeUpdate, { passive: true });
					cleanups.push(() => {
						container.removeEventListener('scroll', scheduleFadeUpdate);
						if (rafId) cancelAnimationFrame(rafId);
					});
					updateFns.push(applyFadeState);
					applyFadeState();
				}

				const refreshAll = () => {
					for (const update of updateFns) update();
				};

				window.addEventListener('resize', refreshAll);
				window.addEventListener('toc:refresh', refreshAll);
				cleanups.push(() => window.removeEventListener('resize', refreshAll));
				cleanups.push(() => window.removeEventListener('toc:refresh', refreshAll));

				window.__tocFadeCleanup = () => {
					for (const fn of cleanups) fn();
				};
			};

			const initImageLightbox = () => {
				// Bind once globally; route swaps re-render nodes but should not duplicate listeners.
				if (window.__imgLightboxBound) return;
				window.__imgLightboxBound = true;

				let lockedScrollY = 0;
				const bodyStyleBeforeLock = {
					position: '',
					top: '',
					left: '',
					right: '',
					width: '',
					overflow: '',
				};
				let isBodyLocked = false;

				const getLightboxElements = () => {
					const overlay = document.getElementById('img-lightbox');
					const target = document.getElementById('img-lightbox-target');
					const caption = document.getElementById('img-lightbox-caption');
					return { overlay, target, caption };
				};

				const closeLightbox = () => {
					const { overlay, target, caption } = getLightboxElements();
					if (!overlay || !target || overlay.classList.contains('hidden')) return;
					if (overlay.classList.contains('is-closing')) return;

					const finishClose = () => {
						overlay.classList.add('hidden');
						overlay.classList.remove('flex', 'is-closing');
						overlay.setAttribute('aria-hidden', 'true');
						target.setAttribute('src', '');
						target.setAttribute('alt', '');
						if (caption) caption.textContent = '';

						if (isBodyLocked) {
							document.body.style.position = bodyStyleBeforeLock.position;
							document.body.style.top = bodyStyleBeforeLock.top;
							document.body.style.left = bodyStyleBeforeLock.left;
							document.body.style.right = bodyStyleBeforeLock.right;
							document.body.style.width = bodyStyleBeforeLock.width;
							document.body.style.overflow = bodyStyleBeforeLock.overflow;
							window.scrollTo(0, lockedScrollY);
							isBodyLocked = false;
						}
					};

					// Brief fade-out unless the user prefers reduced motion.
					if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
						finishClose();
						return;
					}
					overlay.classList.add('is-closing');
					window.setTimeout(finishClose, 180);
				};

				const openLightbox = (src, altText) => {
					const { overlay, target, caption } = getLightboxElements();
					if (!overlay || !target || !src) return;
					if (caption) caption.textContent = altText || '';

					if (!isBodyLocked) {
						lockedScrollY = window.scrollY;
						bodyStyleBeforeLock.position = document.body.style.position;
						bodyStyleBeforeLock.top = document.body.style.top;
						bodyStyleBeforeLock.left = document.body.style.left;
						bodyStyleBeforeLock.right = document.body.style.right;
						bodyStyleBeforeLock.width = document.body.style.width;
						bodyStyleBeforeLock.overflow = document.body.style.overflow;
						document.body.style.position = 'fixed';
						document.body.style.top = `-${lockedScrollY}px`;
						document.body.style.left = '0';
						document.body.style.right = '0';
						document.body.style.width = '100%';
						document.body.style.overflow = 'hidden';
						isBodyLocked = true;
					}

					target.setAttribute('src', src);
					target.setAttribute('alt', altText || '');
					overlay.classList.remove('hidden');
					overlay.classList.add('flex');
					overlay.setAttribute('aria-hidden', 'false');
				};

				document.addEventListener('click', (event) => {
					const rawTarget = event.target;
					if (!(rawTarget instanceof Element)) return;

					const { overlay } = getLightboxElements();
					if (overlay && !overlay.classList.contains('hidden')) {
						// Any click inside the open lightbox dismisses it (image included).
						if (overlay.contains(rawTarget)) {
							event.preventDefault();
							closeLightbox();
							return;
						}
					}

					if (!(rawTarget instanceof HTMLImageElement)) return;
					if (!rawTarget.closest('.markdown-prose')) return;

					const anchor = rawTarget.closest('a');
					if (anchor) event.preventDefault();

					const imgSrc = rawTarget.currentSrc || rawTarget.src;
					if (!imgSrc) return;
					openLightbox(imgSrc, rawTarget.alt || '');
				});

				document.addEventListener('keydown', (event) => {
					if (event.key !== 'Escape') return;
					closeLightbox();
				});
			};

			const resetPageScrollLocks = () => {
				// Defensive unlock protects against interrupted lightbox flows during route changes.
				document.documentElement.classList.remove('overflow-hidden');
				const topOffset = Number.parseInt(document.body.style.top || '0', 10);
				const shouldRestoreBody = document.body.style.position === 'fixed';
				if (!shouldRestoreBody) return;
				document.body.style.position = '';
				document.body.style.top = '';
				document.body.style.left = '';
				document.body.style.right = '';
				document.body.style.width = '';
				document.body.style.overflow = '';
				if (!Number.isNaN(topOffset) && topOffset < 0) {
					window.scrollTo(0, Math.abs(topOffset));
				}
			};

			const initBackToTop = () => {
				const button = document.querySelector('[data-back-to-top]');
				if (!(button instanceof HTMLElement)) return;

				const ring = button.querySelector('[data-back-to-top-progress]');
				const circumference = 2 * Math.PI * 21;
				if (ring instanceof SVGElement) {
					ring.style.strokeDasharray = String(circumference);
					ring.style.strokeDashoffset = String(circumference);
				}

				let rafId = 0;
				const update = () => {
					rafId = 0;
					const doc = document.documentElement;
					const max = Math.max(1, doc.scrollHeight - window.innerHeight);
					const progress = Math.min(1, Math.max(0, window.scrollY / max));
					// Surface while scrolling; fade out 3s after scrolling stops, unless
						// the pointer/focus is holding it (tracked via data-held).
						if (window.scrollY > 480) {
							button.classList.add('is-visible');
							if (window.__backToTopIdle) clearTimeout(window.__backToTopIdle);
							window.__backToTopIdle = window.setTimeout(() => {
								window.__backToTopIdle = 0;
								if (button.dataset.held !== 'true') button.classList.remove('is-visible');
							}, 3000);
						} else {
							if (window.__backToTopIdle) { clearTimeout(window.__backToTopIdle); window.__backToTopIdle = 0; }
							button.classList.remove('is-visible');
						}
					if (ring instanceof SVGElement) {
						ring.style.strokeDashoffset = String(circumference * (1 - progress));
					}
				};
				const schedule = () => {
					if (!rafId) rafId = requestAnimationFrame(update);
				};

				if (button.dataset.bound !== 'true') {
					button.dataset.bound = 'true';
						// Hover/focus holds the button visible so it never vanishes mid-reach.
						const holdBackToTop = () => {
							button.dataset.held = 'true';
							if (window.__backToTopIdle) { clearTimeout(window.__backToTopIdle); window.__backToTopIdle = 0; }
							if (window.scrollY > 480) button.classList.add('is-visible');
						};
						const releaseBackToTop = () => {
							button.dataset.held = 'false';
							if (window.scrollY > 480) {
								if (window.__backToTopIdle) clearTimeout(window.__backToTopIdle);
								window.__backToTopIdle = window.setTimeout(() => {
									window.__backToTopIdle = 0;
									if (button.dataset.held !== 'true') button.classList.remove('is-visible');
								}, 3000);
							}
						};
						button.addEventListener('pointerenter', holdBackToTop);
						button.addEventListener('focusin', holdBackToTop);
						button.addEventListener('pointerleave', releaseBackToTop);
						button.addEventListener('focusout', releaseBackToTop);
					button.addEventListener('click', () => {
						const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
						window.scrollTo({ top: 0, behavior: reduced ? 'auto' : 'smooth' });
					});
				}

				// Scroll/resize listeners bind once and dispatch to the current page's handler.
				window.__backToTopSchedule = schedule;
				if (window.__backToTopScrollBound !== true) {
					window.__backToTopScrollBound = true;
					const dispatch = () => {
						if (typeof window.__backToTopSchedule === 'function') window.__backToTopSchedule();
					};
					window.addEventListener('scroll', dispatch, { passive: true });
					window.addEventListener('resize', dispatch);
				}
				update();
			};

			const onPostPageLoad = () => {
				// Centralize post-page bootstrapping so astro:page-load and astro:after-swap stay identical.
				resetPageScrollLocks();
				scrollToTopIfNoHash();
				initTocActiveState();
				initTocScrollFades();
				initImageLightbox();
				initBackToTop();
			};

			onPostPageLoad();

			// Code block enhancements (copy button, fold)
			(function() {
				const CONFIG = { maxHeight: 400, copyTimeout: 2000 };
				const setCodeActionsVisible = (pre, visible) => {
					if (!(pre instanceof HTMLElement)) return;
					pre.dataset.codeActionsVisible = visible ? 'true' : 'false';
				};
				const preEls = document.querySelectorAll('.markdown-prose pre');
				preEls.forEach((pre) => {
					if (pre.dataset.codeEnhanced) return;
					pre.dataset.codeEnhanced = 'true';
					pre.dataset.codeActionsVisible = 'false';
					pre.style.position = 'relative';
					const code = pre.querySelector('code');
					const codeText = code?.textContent || '';
					const shouldCollapse = pre.scrollHeight > CONFIG.maxHeight;
					const lang = (pre.className.match(/language-(\w+)/) || ['',''])[1] || (code?.className?.match(/language-(\w+)/) || ['',''])[1] || pre.getAttribute('data-language');
					const langSpan = document.createElement('span');
					langSpan.className = 'code-lang-label';
					langSpan.textContent = lang || '';
					const btn = document.createElement('button');
					btn.className = 'code-copy-btn';
					btn.type = 'button';
					btn.setAttribute('aria-label', 'Copy code');
					btn.innerHTML = '<svg class="copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg><span class="copy-text">Copy</span>';
					btn.onclick = async (e) => {
						e.preventDefault();
						e.stopPropagation();
						setCodeActionsVisible(pre, true);
						try {
							await navigator.clipboard.writeText(codeText);
							btn.querySelector('.copy-text').textContent = 'Copied!';
							btn.querySelector('.copy-icon').innerHTML = '<path d="M20 6L9 17l-5-5"></path>';
							setTimeout(() => {
								btn.querySelector('.copy-text').textContent = 'Copy';
								btn.querySelector('.copy-icon').innerHTML = '<rect x="9" y="9" width="13" height="13" rx="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>';
							}, CONFIG.copyTimeout);
						} catch (err) { console.error('Copy failed:', err); }
					};
					const actionBar = document.createElement('div');
					actionBar.className = 'code-action-bar';
					if (lang) actionBar.appendChild(langSpan);
					actionBar.appendChild(btn);
					pre.appendChild(actionBar);

					const showActions = () => setCodeActionsVisible(pre, true);
					const hideActions = () => setCodeActionsVisible(pre, false);
					pre.addEventListener('pointerenter', showActions);
					pre.addEventListener('pointerleave', hideActions);
					pre.addEventListener('focusin', showActions);
					pre.addEventListener('focusout', (event) => {
						if (pre.contains(event.relatedTarget)) return;
						hideActions();
					});
					pre.addEventListener('click', (event) => {
						if (!(event.target instanceof Element)) return;
						if (event.target.closest('.code-copy-btn, .code-expand-btn')) return;
						showActions();
					});
					if (shouldCollapse) {
						pre.style.maxHeight = CONFIG.maxHeight + 'px';
						pre.style.overflow = 'hidden';
						const expBtn = document.createElement('button');
						expBtn.className = 'code-expand-btn';
						expBtn.type = 'button';
						expBtn.setAttribute('data-expanded', 'false');
						expBtn.textContent = 'Expand Code';
						let expanded = false;
						expBtn.onclick = (e) => {
							e.preventDefault();
							e.stopPropagation();
							expanded = !expanded;
							pre.style.maxHeight = expanded ? 'none' : CONFIG.maxHeight + 'px';
							pre.style.overflowX = 'auto';
							pre.style.overflowY = expanded ? 'auto' : 'hidden';
							expBtn.setAttribute('data-expanded', String(expanded));
							expBtn.textContent = expanded ? 'Collapse' : 'Expand Code';
							setCodeActionsVisible(pre, true);
						};
						pre.appendChild(expBtn);
					}
				});
			})();

			if (!window.__blogPostEventsBound) {
				document.addEventListener('astro:page-load', onPostPageLoad);
				document.addEventListener('astro:after-swap', onPostPageLoad);
				window.__blogPostEventsBound = true;
			}
		</script>
	</body>
</html>









