---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import TagBadges from './TagBadges.astro';
import { getPostAnalyticsKey } from '../utils/postAnalytics';

/*
 * Reusable post preview card used across all list surfaces.
 * Standardizes metadata rendering (dates, tags) and hover interactions.
 */
interface Props {
	post: CollectionEntry<'blog'>;
	base?: string;
	titleTag?: 'h2' | 'h3' | 'h4';
	titleClass?: string;
	descriptionClass?: string;
	maxMobile?: number; // max tags to show on mobile (rest hidden via css)
	maxDesktop?: number; // max tags to show on desktop
	reloadOnNavigate?: boolean;
}

const {
	post,
	base = import.meta.env.BASE_URL,
	titleTag = 'h2',
	titleClass = 'mt-2 text-xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100',
	descriptionClass = 'mt-2 font-body leading-8 text-zinc-600 dark:text-zinc-300',
	maxMobile = 3,
	maxDesktop = 3,
	reloadOnNavigate = false,
} = Astro.props as Props;

const tags = (post.data.tags ?? []).filter((tag) => tag.trim().length > 0);
const analyticsKey = getPostAnalyticsKey(post);
const Heading = titleTag;
---

<div class="group relative py-6 first:pt-0 last:pb-0" data-reveal>
	<!-- Decorative vertical highlight bar shown on hover. -->
	<span
		class="absolute left-[-1.25rem] top-0 bottom-0 w-[4px] scale-y-0 rounded-full bg-gradient-to-b from-[rgb(180,126,36)] to-[rgba(180,126,36,0.3)] opacity-0 transition duration-200 group-hover:scale-y-100 group-hover:opacity-100 dark:from-[rgb(226,190,110)] dark:to-[rgba(226,190,110,0.2)] md:left-[-1.5rem]"
		aria-hidden="true"
	></span>

	{tags.length > 0 && (
		<div class="absolute right-0 top-6 hidden md:block">
			<TagBadges tags={tags} maxMobile={maxMobile} maxDesktop={maxDesktop} />
		</div>
	)}

	<a
		href={`${base}blog/${post.id}/`}
		class="block no-underline"
		data-astro-reload={reloadOnNavigate ? '' : undefined}
	>
		<p class="m-0 flex items-center gap-1.5 text-xs text-zinc-500 dark:text-zinc-400">
			<FormattedDate date={post.data.pubDate} />
			<span aria-hidden="true">&middot;</span>
			<span class="inline-flex items-center gap-1" data-post-card-views-root={analyticsKey}>
				<svg viewBox="0 0 24 24" class="h-3.5 w-3.5 opacity-70" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
					<path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z" stroke-linecap="round" stroke-linejoin="round" />
					<circle cx="12" cy="12" r="3" stroke-linecap="round" stroke-linejoin="round" />
				</svg>
				<span data-post-card-views>...</span>
			</span>
		</p>
		<Heading class:list={[titleClass, tags.length > 0 && 'md:pr-24 lg:pr-28']}>{post.data.title}</Heading>
		<p class={descriptionClass}>{post.data.description}</p>
	</a>
</div>

<script is:inline>
	(() => {
		const fmt = window.__formatCompactViewCount || function(c) { return String(Number(c) || 0); };

		const loadPostCardViews = async () => {
			const roots = Array.from(document.querySelectorAll('[data-post-card-views-root]'));
			if (!roots.length) return;

			const apiBase = window.__API_BASE || 'https://tavricccc-worker.tavric.workers.dev';
			const uniqueKeys = [...new Set(
				roots
					.map((root) => root.getAttribute('data-post-card-views-root') || '')
					.filter(Boolean)
			)];

			try {
				const response = await fetch(apiBase + '/api/views/batch?posts=' + encodeURIComponent(uniqueKeys.join(',')));
				if (response.ok) {
					const data = await response.json();
					var viewsMap = data.views || {};
					uniqueKeys.forEach(function(key) {
						var text = fmt(viewsMap[key] ?? 0);
						document
							.querySelectorAll('[data-post-card-views-root="' + key + '"] [data-post-card-views]')
							.forEach(function(node) { node.textContent = text; });
					});
					return;
				}
			} catch {}

			await Promise.all(uniqueKeys.map(async (key) => {
				let text = '0';
				try {
					const response = await fetch(apiBase + '/api/views?post=' + encodeURIComponent(key));
					if (response.ok) {
						const data = await response.json();
						text = fmt(data?.views ?? 0);
					}
				} catch {}
				document
					.querySelectorAll('[data-post-card-views-root="' + key + '"] [data-post-card-views]')
					.forEach(function(node) { node.textContent = text; });
			}));
		};

		if (!window.__postCardViewsBound) {
			document.addEventListener('astro:page-load', loadPostCardViews);
			document.addEventListener('astro:after-swap', loadPostCardViews);
			window.__postCardViewsBound = true;
		}

		loadPostCardViews();
	})();
</script>
