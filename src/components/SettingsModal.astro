---
// SettingsModal.astro - User settings modal with avatar editing
---

<div
	id="settings-modal"
	class="fixed inset-0 z-[100] invisible opacity-0 flex items-center justify-center bg-black/40 backdrop-blur-sm transition-opacity duration-200 ease-out"
	aria-hidden="true"
>
	<div
		class="modal-content mx-4 w-[380px] rounded-xl bg-white p-6 shadow-xl transition-all duration-200 ease-out dark:bg-zinc-900 scale-95 opacity-0"
		role="dialog"
		aria-modal="true"
		aria-labelledby="settings-modal-title"
		id="settings-modal-content"
	>
		<div class="flex items-center justify-between mb-6">
			<h2 id="settings-modal-title" class="text-xl font-semibold text-zinc-900 dark:text-zinc-100">
				Settings
			</h2>
			<button
				type="button"
				id="settings-modal-close"
				class="p-1 rounded-lg text-zinc-500 hover:text-zinc-700 hover:bg-zinc-100 dark:text-zinc-400 dark:hover:text-zinc-200 dark:hover:bg-zinc-800 transition-colors"
			>
				<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
					<path d="M6 18L18 6M6 6l12 12" />
				</svg>
			</button>
		</div>

		<div class="flex flex-col items-center py-4">
			<img
				id="settings-avatar"
				src="https://img.danarnoux.com/misc/DanArnoux.webp"
				alt="User avatar"
				class="h-20 w-20 rounded-full border-2 border-zinc-200 object-cover dark:border-zinc-700"
			/>
			<h3 id="settings-username" class="mt-3 text-lg font-semibold text-zinc-900 dark:text-zinc-100">
				User
			</h3>
			<p id="settings-login" class="text-sm text-zinc-500 dark:text-zinc-400">
				@login
			</p>
		</div>

		<div class="space-y-4">
			<div class="rounded-xl border border-zinc-200 p-4 dark:border-zinc-800">
				<p class="text-sm font-medium text-zinc-900 dark:text-zinc-100">Avatar URL</p>
				<p class="mt-1 text-xs text-zinc-500 dark:text-zinc-400">Paste an image URL. We display avatars as a centered 1:1 crop automatically.</p>
				<input
					id="settings-avatar-url"
					type="url"
					placeholder="https://example.com/avatar.png"
					class="mt-3 w-full rounded-lg border border-zinc-200 px-3 py-2.5 text-sm text-zinc-900 placeholder-zinc-400 focus:border-zinc-400 focus:outline-none dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-100 dark:placeholder-zinc-500"
				/>
			</div>

			<div class="rounded-xl border border-zinc-200 p-4 dark:border-zinc-800">
				<p class="text-sm font-medium text-zinc-900 dark:text-zinc-100">Username</p>
				<p class="mt-1 text-xs text-zinc-500 dark:text-zinc-400">Display name shown on your comments. 2-30 characters. Will be reviewed by AI.</p>
				<input
					id="settings-username-input"
					type="text"
					placeholder="Your username"
					minlength="2"
					maxlength="30"
					class="mt-3 w-full rounded-lg border border-zinc-200 px-3 py-2.5 text-sm text-zinc-900 placeholder-zinc-400 focus:border-zinc-400 focus:outline-none dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-100 dark:placeholder-zinc-500"
				/>
			</div>

			<p id="settings-status" class="min-h-[1.25rem] text-sm text-zinc-500 dark:text-zinc-400"></p>

			<div class="flex gap-3">
				<button
					type="button"
					id="settings-save"
					class="flex-1 rounded-lg bg-zinc-900 px-4 py-2.5 text-sm font-medium text-white transition-colors hover:bg-zinc-700 dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-zinc-200"
				>
					Save
				</button>
				<button
					type="button"
					id="settings-reset"
					class="rounded-lg border border-zinc-200 px-4 py-2.5 text-sm font-medium text-zinc-700 transition-colors hover:bg-zinc-100 dark:border-zinc-700 dark:text-zinc-300 dark:hover:bg-zinc-800"
				>
					Reset
				</button>
			</div>
		</div>
	</div>
</div>

<script>
	import { updateProfileAvatar, updateProfileUsername } from '../lib/auth';

	const initSettingsModal = () => {
		const modal = document.getElementById('settings-modal');
		const modalClose = document.getElementById('settings-modal-close');
		const settingsAvatar = document.getElementById('settings-avatar') as HTMLImageElement | null;
		const settingsUsername = document.getElementById('settings-username');
		const settingsLogin = document.getElementById('settings-login');
		const avatarUrlInput = document.getElementById('settings-avatar-url') as HTMLInputElement | null;
		const usernameInput = document.getElementById('settings-username-input') as HTMLInputElement | null;
		const saveButton = document.getElementById('settings-save') as HTMLButtonElement | null;
		const resetButton = document.getElementById('settings-reset') as HTMLButtonElement | null;
		const status = document.getElementById('settings-status');
		const fallbackAvatar = 'https://img.danarnoux.com/misc/DanArnoux.webp';
		let currentAvatar = '';
		let currentUsername = '';
		let currentLogin = '';

		const openModal = async () => {
			if (!modal) return;

			// Fetch current user info
			const { getCurrentUser } = window.__auth || {};
			if (getCurrentUser) {
				try {
					const user = await getCurrentUser();
					if (user) {
						currentAvatar = user.avatar || '';
						currentUsername = user.username || user.name || '';
						currentLogin = user.login || user.username || '';
						if (settingsAvatar) settingsAvatar.src = currentAvatar || fallbackAvatar;
						if (avatarUrlInput) avatarUrlInput.value = currentAvatar;
						if (settingsUsername) settingsUsername.textContent = currentUsername || 'User';
						if (settingsLogin) settingsLogin.textContent = '@' + currentLogin;
						if (usernameInput) usernameInput.value = currentUsername;
						if (status) status.textContent = '';
					}
				} catch (e) {
					console.error('Failed to load user info:', e);
				}
			}

			requestAnimationFrame(() => {
				modal.classList.remove('opacity-0', 'invisible');
				modal.classList.add('opacity-100');
				const content = modal.querySelector('.modal-content');
				if (content) {
					content.classList.remove('scale-95', 'opacity-0');
					content.classList.add('scale-100', 'opacity-100');
				}
				modal.setAttribute('aria-hidden', 'false');
			});
		};

		const closeModal = () => {
			if (!modal) return;
			modal.classList.remove('opacity-100');
			modal.classList.add('opacity-0');
			const content = modal.querySelector('.modal-content');
			if (content) {
				content.classList.remove('scale-100', 'opacity-100');
				content.classList.add('scale-95', 'opacity-0');
			}
			setTimeout(() => modal.classList.add('invisible'), 200);
			modal.setAttribute('aria-hidden', 'true');
		};

		const setStatus = (message: string, tone: 'default' | 'error' | 'success' = 'default') => {
			if (!status) return;
			status.textContent = message;
			status.className = 'min-h-[1.25rem] text-sm';
			if (tone === 'error') {
				status.classList.add('text-red-600', 'dark:text-red-400');
			} else if (tone === 'success') {
				status.classList.add('text-green-600', 'dark:text-green-400');
			} else {
				status.classList.add('text-zinc-500', 'dark:text-zinc-400');
			}
		};

		const broadcastUpdate = (avatarUrl: string, username: string, login: string) => {
			window.dispatchEvent(new CustomEvent('blog:user-updated', {
				detail: { avatarUrl, username, login },
			}));
		};

		const saveAll = async () => {
			if (!saveButton || !avatarUrlInput || !usernameInput) return;
			saveButton.disabled = true;
			const originalLabel = saveButton.textContent;
			saveButton.textContent = 'Saving...';
			setStatus('Working...');

			try {
				const nextAvatarUrl = avatarUrlInput.value.trim();
				const nextUsername = usernameInput.value.trim();

				// Update avatar if changed
				if (nextAvatarUrl && nextAvatarUrl !== currentAvatar) {
					const avatarResult = await updateProfileAvatar(nextAvatarUrl);
					if (!avatarResult.ok || !avatarResult.user) {
						throw new Error(avatarResult.error ?? 'Failed to save avatar');
					}
					currentAvatar = avatarResult.user.avatar || nextAvatarUrl;
				}

				// Update username if changed
				if (nextUsername && nextUsername !== currentUsername) {
					const usernameResult = await updateProfileUsername(nextUsername);
					if (!usernameResult.ok || !usernameResult.user) {
						throw new Error(usernameResult.error ?? 'Failed to save username');
					}
					currentUsername = usernameResult.user.name || usernameResult.user.username || nextUsername;
				}

				if (settingsAvatar) settingsAvatar.src = currentAvatar || fallbackAvatar;
				if (settingsUsername) settingsUsername.textContent = currentUsername || 'User';
				if (settingsLogin) settingsLogin.textContent = '@' + (currentLogin || currentUsername);
				if (avatarUrlInput) avatarUrlInput.value = currentAvatar;
				if (usernameInput) usernameInput.value = currentUsername;
				broadcastUpdate(currentAvatar, currentUsername, currentLogin || currentUsername);
				setStatus('Settings saved.', 'success');
			} catch (error) {
				const message = error instanceof Error ? error.message : 'Failed to save settings';
				setStatus(message, 'error');
			} finally {
				saveButton.disabled = false;
				saveButton.textContent = originalLabel || 'Save';
			}
		};

		const resetForm = () => {
			if (avatarUrlInput) avatarUrlInput.value = currentAvatar;
			if (usernameInput) usernameInput.value = currentUsername;
			if (settingsAvatar) settingsAvatar.src = currentAvatar || fallbackAvatar;
			setStatus('');
		};

		// Listen for custom open-settings event
		modal?.addEventListener('open-settings', openModal);

		// Close on backdrop click
		modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });

		// Close on close button click
		modalClose?.addEventListener('click', closeModal);
		saveButton?.addEventListener('click', saveAll);
		resetButton?.addEventListener('click', resetForm);
		avatarUrlInput?.addEventListener('input', () => {
			const value = avatarUrlInput.value.trim();
			if (settingsAvatar) settingsAvatar.src = value || currentAvatar || fallbackAvatar;
		});

		// Close on Escape key
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && modal && !modal.classList.contains('invisible')) closeModal();
		});
	};

	initSettingsModal();
	document.addEventListener('astro:page-load', initSettingsModal);
	document.addEventListener('astro:after-swap', initSettingsModal);
</script>
