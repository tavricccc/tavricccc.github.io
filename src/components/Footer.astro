---
import ContactModal from './ContactModal.astro';

const today = new Date();
---

<footer class="mt-16 border-t border-zinc-200 py-8 transition-colors duration-200 dark:border-zinc-800">
	<div class="page-shell flex flex-col items-center justify-between gap-4 text-sm text-zinc-500 dark:text-zinc-400 md:flex-row">
		<p class="m-0">&copy; {today.getFullYear()} Tavric. All rights reserved.</p>
		<div class="flex flex-wrap items-center gap-3">
			<a
				href="https://github.com/Dancncn/DansBlog"
				target="_blank"
				rel="noreferrer"
				class="inline-flex items-center gap-2 rounded-full border border-zinc-200/80 bg-white/70 px-3 py-1.5 text-xs font-medium text-zinc-500 no-underline shadow-[0_8px_20px_rgba(15,23,42,0.04)] transition-all duration-200 hover:-translate-y-0.5 hover:border-zinc-300 hover:bg-white hover:text-zinc-800 dark:border-zinc-800/80 dark:bg-zinc-900/70 dark:text-zinc-400 dark:hover:border-zinc-700 dark:hover:bg-zinc-900 dark:hover:text-zinc-100"
			>
				<svg viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true">
					<path d="M6 3a3 3 0 0 1 3 3c0 1.306-.835 2.417-2 2.83v6.34A3.001 3.001 0 1 1 5 15.17V8.83A3.001 3.001 0 0 1 6 3Zm0 2a1 1 0 1 0 0 2 1 1 0 0 0 0-2Zm0 12a1 1 0 1 0 0 2 1 1 0 0 0 0-2Zm9-14a3 3 0 1 1-1 5.83V10a3 3 0 0 1-3 3h-1a1 1 0 1 1 0-2h1a1 1 0 0 0 1-1V8.83A3.001 3.001 0 0 1 15 3Zm0 2a1 1 0 1 0 0 2 1 1 0 0 0 0-2Z" />
				</svg>
				<span>Forked from Dancncn/DansBlog</span>
			</a>
			<button
				type="button"
				id="contact-button"
				class="apple-float-chip inline-flex items-center rounded-full border border-zinc-200/80 bg-white/70 px-3.5 py-1.5 text-sm font-medium text-zinc-600 shadow-[0_10px_24px_rgba(15,23,42,0.04)] backdrop-blur-sm transition dark:border-zinc-700/80 dark:bg-zinc-950/55 dark:text-zinc-300"
			>
				<span class="apple-float-label">
					<span>Contact</span>
					<svg viewBox="0 0 20 20" class="h-4 w-4 opacity-70" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
						<path d="M3.75 6.75h12.5" stroke-linecap="round" />
						<path d="M3.75 10h12.5" stroke-linecap="round" />
						<path d="M3.75 13.25h8.5" stroke-linecap="round" />
					</svg>
				</span>
			</button>
		</div>
	</div>
</footer>

<ContactModal />

<script>
	const initContactButton = () => {
		const contactButton = document.getElementById('contact-button');
		if (contactButton) {
			contactButton.addEventListener('click', () => {
				(window as any).openContactModal?.();
			});
		}
	};

	initContactButton();
	document.addEventListener('astro:page-load', initContactButton);
</script>
