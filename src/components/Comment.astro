---
import { API_BASE } from '../lib/config';

interface Props {
	postSlug: string;
}

const { postSlug } = Astro.props;
---

<section class="comments-section mt-12 border-t border-zinc-200 pt-8 dark:border-zinc-700">
	<h2 class="mb-6 text-2xl font-semibold text-zinc-900 dark:text-zinc-100">Comments</h2>

	<div id="comment-form-container" class="mt-8">
		<!-- Show login prompt when not logged in -->
		<div id="login-prompt" class="hidden">
			<p class="text-zinc-600 dark:text-zinc-400">
				<a href={`${API_BASE}/api/auth/github/start`} class="text-blue-600 hover:underline dark:text-blue-400">
					Login with GitHub
				</a>
				to comment
			</p>
		</div>

		<!-- Comment form - visible when logged in -->
		<form id="comment-form" class="hidden space-y-4">
			<div id="reply-to-indicator" class="hidden text-sm text-zinc-500 dark:text-zinc-400">
				Replying to: <span id="reply-to-name"></span>
				<button type="button" id="cancel-reply" class="ml-2 text-blue-600 hover:underline dark:text-blue-400">Cancel</button>
			</div>
			<textarea
				id="comment-content"
				name="content"
				rows="4"
				required
				placeholder="Write a comment..."
				class="w-full rounded-lg border border-zinc-200 bg-zinc-50 p-3 text-zinc-900 placeholder-zinc-400 focus:border-zinc-400 focus:outline-none focus:ring-1 focus:ring-zinc-400 dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-100 dark:placeholder-zinc-500"
			></textarea>
			<p class="text-xs text-zinc-400 dark:text-zinc-500">Please post constructive comments. All content will be reviewed by AI before display.</p>
			<div class="flex items-center justify-between">
				<button
					type="submit"
					class="rounded-lg bg-zinc-900 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-zinc-700 dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-zinc-200"
				>
					Submit Comment
				</button>
				<span id="daily-limit-msg" class="hidden text-sm text-zinc-500 dark:text-zinc-400"></span>
			</div>
		</form>
	</div>

	<!-- Comments list -->
	<div id="comments-container" class="mt-8 space-y-6" data-comments-container data-post-slug={postSlug}></div>
</section>

<script>
	const API_BASE = (window as any).__API_BASE || 'https://api.danarnoux.com';

	const { storeTokenFromHash, getAuthToken, getCurrentUser } = (window as any).__auth || {};

	const escapeHtml = (str: string): string => {
		return str
			.replace(/&/g, '&amp;')
			.replace(/</g, '&lt;')
			.replace(/>/g, '&gt;')
			.replace(/"/g, '&quot;')
			.replace(/'/g, '&#39;');
	};

	interface CommentUser {
		id?: string;
		login?: string;
		name?: string | null;
		avatarUrl?: string | null;
		profileUrl?: string | null;
	}

	interface CommentData {
		id: string;
		parentId?: string | null;
		postSlug?: string;
		body?: string;
		content?: string;
		status?: string;
		createdAt?: string;
		created_at?: string;
		user?: CommentUser;
		replies?: CommentData[];
	}

	const formatRelativeTime = (dateString: string) => {
		const date = new Date(dateString);
		const now = new Date();
		const diff = now.getTime() - date.getTime();
		const seconds = Math.floor(diff / 1000);
		const minutes = Math.floor(seconds / 60);
		const hours = Math.floor(minutes / 60);
		const days = Math.floor(hours / 24);

		if (days > 7) {
			return date.toLocaleDateString();
		} else if (days > 0) {
			return `${days} day${days > 1 ? 's' : ''} ago`;
		} else if (hours > 0) {
			return `${hours} hour${hours > 1 ? 's' : ''} ago`;
		} else if (minutes > 0) {
			return `${minutes} minute${minutes > 1 ? 's' : ''} ago`;
		} else {
			return 'Just now';
		}
	};

	let currentUser: CommentUser | null = null;
	let replyingTo: { id: string; name: string } | null = null;

	const renderComment = (comment: CommentData, isReply = false): string => {
		const userName = escapeHtml(comment.user?.name || comment.user?.login || 'Anonymous');
		const avatarUrl = escapeHtml(comment.user?.avatarUrl || 'https://img.danarnoux.com/misc/DanArnoux.webp');
		const commentId = escapeHtml(comment.id);
		const commentBody = escapeHtml(comment.content || comment.body || '');
		const replyCount = comment.replies?.length || 0;
		const replyButton = !isReply && currentUser
			? `<button class="reply-btn text-sm text-blue-600 hover:underline dark:text-blue-400" data-comment-id="${commentId}" data-user-name="${userName}">Reply</button>`
			: '';

		return `
			<div class="flex gap-4 ${isReply ? 'ml-8 mt-4' : ''}">
				<img
					src="${avatarUrl}"
					alt="${userName} avatar"
					class="h-10 w-10 shrink-0 rounded-full border border-zinc-200 object-cover dark:border-zinc-700"
				/>
				<div class="min-w-0 flex-1">
					<div class="flex items-center gap-2 flex-wrap">
						<span class="font-medium text-zinc-900 dark:text-zinc-100">${userName}</span>
						<span class="text-sm text-zinc-500 dark:text-zinc-400">${formatRelativeTime(comment.createdAt || comment.created_at || '')}</span>
						${comment.status === 'pending' ? '<span class="text-xs text-yellow-600">(pending)</span>' : ''}
					</div>
					<p class="mt-1 text-zinc-700 dark:text-zinc-300">${commentBody}</p>
					<div class="mt-1 flex items-center gap-3">
						${replyButton}
						${replyCount > 0 ? `<span class="text-sm text-zinc-500 dark:text-zinc-400">${replyCount} ${replyCount === 1 ? 'reply' : 'replies'}</span>` : ''}
					</div>
				</div>
			</div>
			${comment.replies?.length ? `<div class="replies-container">${comment.replies.map((reply) => renderComment(reply, true)).join('')}</div>` : ''}
		`;
	};

	const renderComments = (comments: CommentData[]) => {
		const container = document.getElementById('comments-container');
		if (!container) return;

		if (!comments || comments.length === 0) {
			container.innerHTML = '<p class="text-zinc-500 dark:text-zinc-400">No comments yet. Be the first to comment!</p>';
			return;
		}

		container.innerHTML = comments.map(c => renderComment(c)).join('');
		attachReplyHandlers();
	};

	// Attach reply button handlers
	const attachReplyHandlers = () => {
		document.querySelectorAll('.reply-btn').forEach(btn => {
			btn.addEventListener('click', (e) => {
				const target = e.target as HTMLElement;
				const commentId = target.dataset.commentId;
				const userName = target.dataset.userName;
				if (commentId && userName) {
					replyingTo = { id: commentId, name: userName };
					document.getElementById('reply-to-indicator')?.classList.remove('hidden');
					document.getElementById('reply-to-name')!.textContent = userName;
					document.getElementById('comment-content')?.focus();
				}
			});
		});
	};

	// Load comments
	async function loadComments(postSlug: string) {
		const container = document.getElementById('comments-container');
		if (!container) return;

		try {
			const response = await fetch(`${API_BASE}/api/comments?post_id=${encodeURIComponent(postSlug)}`);
			if (response.ok) {
				const data = await response.json();
				const comments = data?.comments ?? [];
				renderComments(comments);
			}
		} catch (error) {
			console.error('Failed to load comments:', error);
		}
	}

	// Submit comment
	async function submitComment(postSlug: string, content: string, parentId?: string) {
		const token = getAuthToken();
		if (!token) return { ok: false, error: 'Not logged in' };

		const body: Record<string, string> = {
			post_id: postSlug,
			content: content,
		};
		if (parentId) {
			body.parent_id = parentId;
		}

		const response = await fetch(`${API_BASE}/api/comments`, {
			method: 'POST',
			headers: {
				'Content-Type': 'application/json',
				Authorization: `Bearer ${token}`,
			},
			body: JSON.stringify(body),
		});

		const data = await response.json();
		return { ok: response.ok, error: data.error };
	}

	// Initialize comments
	const initComments = async () => {
		const container = document.getElementById('comments-container');
		if (!container) return;

		const postSlug = container.dataset.postSlug;
		if (!postSlug) return;

		storeTokenFromHash();
		currentUser = await getCurrentUser();

		const loginPrompt = document.getElementById('login-prompt');
		const commentForm = document.getElementById('comment-form');

		// Show comment form if logged in
		if (currentUser) {
			if (loginPrompt) loginPrompt.classList.add('hidden');
			if (commentForm) commentForm.classList.remove('hidden');
		} else {
			if (loginPrompt) loginPrompt.classList.remove('hidden');
			if (commentForm) commentForm.classList.add('hidden');
		}

		// Load comments
		loadComments(postSlug);

		// Bind form submit
		const form = document.getElementById('comment-form');
		if (form && form.dataset.bound !== 'true') {
			form.dataset.bound = 'true';

			// Cancel reply handler
			document.getElementById('cancel-reply')?.addEventListener('click', () => {
				replyingTo = null;
				document.getElementById('reply-to-indicator')?.classList.add('hidden');
			});

			form.addEventListener('submit', async (e) => {
				e.preventDefault();
				const textarea = document.getElementById('comment-content') as HTMLTextAreaElement;
				const content = textarea?.value?.trim();
				if (!content) return;

				const button = form.querySelector('button[type="submit"]') as HTMLButtonElement;
				const dailyMsg = document.getElementById('daily-limit-msg');
				if (button) {
					button.disabled = true;
					button.textContent = 'Submitting...';
				}

				const result = await submitComment(postSlug, content, replyingTo?.id);

				if (result.ok) {
					textarea.value = '';
					replyingTo = null;
					document.getElementById('reply-to-indicator')?.classList.add('hidden');
					loadComments(postSlug);
				} else {
					alert(result.error || 'Failed to submit comment.');
					if (result.error?.includes('Daily comment limit')) {
						if (dailyMsg) {
							dailyMsg.textContent = result.error;
							dailyMsg.classList.remove('hidden');
						}
					}
				}

				if (button) {
					button.disabled = false;
					button.textContent = 'Submit Comment';
				}
			});
		}
	};

	initComments();
	document.addEventListener('astro:page-load', initComments);
	document.addEventListener('astro:after-swap', initComments);
</script>
