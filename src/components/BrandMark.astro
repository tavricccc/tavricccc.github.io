---
/*
 * One-stroke signature "T" — the site's brand mark.
 * A single continuous path (crossbar, central sweep, and S-curve flourish)
 * drawn on with a stroke-dash animation at load and replayed on hover.
 * Designed iteratively at 120x100; the dash length is intentionally a little
 * generous so the full mark draws cleanly as the path evolves.
 */
interface Props {
	class?: string;
}
const { class: className } = Astro.props as Props;
---

<svg
	class:list={['brand-mark', className]}
	viewBox="0 0 120 100"
	fill="none"
	xmlns="http://www.w3.org/2000/svg"
	aria-hidden="true"
>
	<defs>
		<linearGradient id="brand-mark-gold" x1="0" y1="0" x2="1" y2="1">
			<stop offset="0" stop-color="#b47e24"></stop>
			<stop offset="0.55" stop-color="#e2be6e"></stop>
			<stop offset="1" stop-color="#966616"></stop>
		</linearGradient>
		<linearGradient id="brand-mark-gold-dark" x1="0" y1="0" x2="1" y2="1">
			<stop offset="0" stop-color="#fad68c"></stop>
			<stop offset="0.55" stop-color="#cda048"></stop>
			<stop offset="1" stop-color="#ffe8b3"></stop>
		</linearGradient>
	</defs>
	<path
		class="brand-mark-path"
		d="M 14 36 C 30 18, 60 14, 88 20 C 101 23, 109 30, 112 39 C 92 30, 65 29, 38 33 C 25 35, 18 40, 20 45 C 24 54, 45 40, 64 23 C 58 42, 52 63, 49 78 C 48 85, 54 89, 61 81 C 69 71, 73 59, 82 50 C 90 42, 100 42, 109 48"
		stroke="url(#brand-mark-gold)"></path>
</svg>
