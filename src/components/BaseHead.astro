---
/*
 * Shared document head for every route.
 * Centralizing this keeps metadata/base-path behavior consistent across environments.
 */
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { SITE_TITLE } from '../consts';

interface Props {
	// Human-readable page title used by document title and social metadata.
	title: string;
	// Summary used by search/social cards and meta description.
	description: string;
	// Optional social preview image; falls back to a local placeholder for consistency.
	image?: ImageMetadata;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = FallbackImage } = Astro.props;
const BASE = import.meta.env.BASE_URL;
const cfWebAnalyticsToken = import.meta.env.PUBLIC_CF_WEB_ANALYTICS_TOKEN;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<!-- Keep View Transitions globally enabled so only targeted links/routes opt out when needed. -->
<ClientRouter />
<link rel="icon" type="image/x-icon" href={`${BASE}image/favicon.ico`} />
<link rel="shortcut icon" href={`${BASE}image/favicon.ico`} />
<link rel="sitemap" href={`${BASE}sitemap-index.xml`} />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={`${BASE}rss.xml`}
/>
<meta name="generator" content={Astro.generator} />

<!-- Font preconnect -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<style is:inline>
	{`
		@font-face {
			font-family: "Alibaba PuHuiTi";
			src: url('${BASE}fonts/AlibabaPuHuiTi-3-55-RegularL3.woff2') format('woff2');
			font-weight: 400;
			font-style: normal;
			font-display: swap;
		}
		@font-face {
			font-family: "Alibaba PuHuiTi";
			src: url('${BASE}fonts/AlibabaPuHuiTi-3-75-SemiBold.woff2') format('woff2');
			font-weight: 600;
			font-style: normal;
			font-display: swap;
		}
	`}
</style>
<!-- UI/body fonts prioritize immediate paint to reduce perceived loading delay. -->
<link
	rel="stylesheet"
	href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Noto+Serif+SC:wght@400;600&display=swap"
/>
<!-- Code font is optional to avoid post-paint metric swaps on large code blocks. -->
<link
	rel="stylesheet"
	href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=optional"
/>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="google-site-verification" content="c9eLQFflOQPGAa5ykLn2PnyXDt5rup4VJNQe3P8hW7Y" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image.src, Astro.url)} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image.src, Astro.url)} />

<script is:inline>
	(() => {
		// Apply theme before hydration to avoid light/dark flash during initial paint.
		const storageKey = 'theme';
		const root = document.documentElement;
		const stored = localStorage.getItem(storageKey);
		const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
		const theme = stored === 'dark' || stored === 'light' ? stored : systemPrefersDark ? 'dark' : 'light';
		root.classList.toggle('dark', theme === 'dark');
		root.dataset.theme = theme;
	})();
</script>
<script is:inline>
	// Token handling and auth functions - expose to window for global access
	(function() {
		// Dynamically determine API base based on current host
		const isLocalhost = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
		const API_BASE = isLocalhost ? 'http://localhost:8787' : 'https://api.danarnoux.com';
		const TOKEN_KEY = 'blog_token';

		// Store on window
		window.__API_BASE = API_BASE;
		window.__TOKEN_KEY = TOKEN_KEY;

		// Read token from URL hash
		function readHashToken() {
			const hash = window.location.hash || '';
			const match = hash.match(/(?:^#|&)token=([^&]+)/);
			if (!match) return null;
			try {
				return decodeURIComponent(match[1]);
			} catch {
				return match[1];
			}
		}

		// Store token from URL hash to localStorage
		function storeTokenFromHash() {
			const token = readHashToken();
			if (!token) return null;
			localStorage.setItem(TOKEN_KEY, token);
			history.replaceState(null, '', window.location.pathname);
			return token;
		}

		// Get auth token
		function getAuthToken() {
			storeTokenFromHash();
			return localStorage.getItem(TOKEN_KEY);
		}

		// Get current user
		async function getCurrentUser() {
			const token = getAuthToken();
			if (!token) return null;

			try {
				const response = await fetch(`${API_BASE}/api/me`, {
					method: 'GET',
					headers: {
						Authorization: `Bearer ${token}`,
					},
				});

				if (!response.ok) {
					if (response.status === 401) {
						localStorage.removeItem(TOKEN_KEY);
					}
					return null;
				}

				const data = await response.json();
				const user = data?.user ?? data ?? null;
				if (!user || typeof user !== 'object') return null;

				return {
					id: user.id ?? '',
					username: user.username ?? user.login ?? user.name ?? '',
					avatar: user.avatar ?? user.avatarUrl ?? user.avatar_url ?? '',
				};
			} catch {
				return null;
			}
		}

		// Logout
		async function logout() {
			const token = getAuthToken();
			if (!token) {
				localStorage.removeItem(TOKEN_KEY);
				return;
			}

			try {
				await fetch(`${API_BASE}/api/auth/logout`, {
					method: 'POST',
					headers: {
						Authorization: `Bearer ${token}`,
					},
				});
			} finally {
				localStorage.removeItem(TOKEN_KEY);
			}
		}

		// Initial token processing on page load
		storeTokenFromHash();

		// Expose to window
		window.__auth = {
			storeTokenFromHash,
			getAuthToken,
			getCurrentUser,
			logout,
		};
	})();
</script>
<script is:inline>
	(() => {
		const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		const supportsFinePointer = window.matchMedia('(pointer: fine)').matches;
		if (prefersReducedMotion || !supportsFinePointer) return;

		let cursorEl = null;
		let rafId = 0;
		let currentX = window.innerWidth / 2;
		let currentY = window.innerHeight / 2;
		let targetX = currentX;
		let targetY = currentY;
		let currentState = 'default';
		let isPressed = false;

		const TEXT_SELECTOR = [
			'p',
			'span',
			'strong',
			'em',
			'blockquote',
			'li',
			'h1',
			'h2',
			'h3',
			'h4',
			'h5',
			'h6',
			'figcaption',
			'td',
			'th',
			'summary',
			'label',
		].join(',');

		const CLICKABLE_SELECTOR = [
			'a',
			'button',
			'summary',
			'label',
			'input',
			'textarea',
			'select',
			'[role="button"]',
			'[role="tab"]',
			'[data-auth-login]',
			'.apple-float-chip',
			'.icon-button',
		].join(',');

		const ensureCursor = () => {
			if (cursorEl?.isConnected) return cursorEl;
			cursorEl = document.createElement('div');
			cursorEl.className = 'app-cursor';
			const target = document.body || document.documentElement;
			target.appendChild(cursorEl);
			document.documentElement.classList.add('has-custom-cursor');
			return cursorEl;
		};

		const updateCursorClasses = () => {
			const el = ensureCursor();
			el.classList.toggle('is-visible', true);
			el.classList.toggle('is-clickable', currentState === 'clickable');
			el.classList.toggle('is-text', currentState === 'text');
			el.classList.toggle('is-pressed', isPressed);
		};

		const animateCursor = () => {
			const el = ensureCursor();
			const easing = currentState === 'text' ? 0.5 : currentState === 'clickable' ? 0.4 : 0.3;
			currentX += (targetX - currentX) * easing;
			currentY += (targetY - currentY) * easing;
			el.style.transform = `translate3d(${currentX}px, ${currentY}px, 0) translate(-50%, -50%)`;
			rafId = window.requestAnimationFrame(animateCursor);
		};

		const isPointInsideRect = (x, y, rect) => {
			return x >= rect.left && x <= rect.right && y >= rect.top && y <= rect.bottom;
		};

		const isTextHit = (target, x, y) => {
			if (!(target instanceof Element)) return false;

			const textElement = target.closest(TEXT_SELECTOR);
			if (!textElement) return false;

			const caretRange = document.caretRangeFromPoint?.(x, y);
			if (caretRange?.startContainer) {
				const node = caretRange.startContainer;
				const parentElement = node.nodeType === Node.TEXT_NODE ? node.parentElement : node;
				if (parentElement instanceof Element && parentElement.closest(TEXT_SELECTOR)) {
					return true;
				}
			}

			if (document.caretPositionFromPoint) {
				const caretPosition = document.caretPositionFromPoint(x, y);
				const node = caretPosition?.offsetNode;
				const parentElement = node?.nodeType === Node.TEXT_NODE ? node.parentElement : node;
				if (parentElement instanceof Element && parentElement.closest(TEXT_SELECTOR)) {
					return true;
				}
			}

			const range = document.createRange();
			const walker = document.createTreeWalker(textElement, NodeFilter.SHOW_TEXT, {
				acceptNode(node) {
					return node.textContent?.trim() ? NodeFilter.FILTER_ACCEPT : NodeFilter.FILTER_REJECT;
				},
			});

			let textNode = walker.nextNode();
			while (textNode) {
				range.selectNodeContents(textNode);
				const rects = range.getClientRects();
				for (const rect of rects) {
					if (isPointInsideRect(x, y, rect)) {
						return true;
					}
				}
				textNode = walker.nextNode();
			}

			return false;
		};

		const setStateFromTarget = (target, x = targetX, y = targetY) => {
			if (!(target instanceof Element)) {
				currentState = 'default';
				updateCursorClasses();
				return;
			}

			if (target.closest(CLICKABLE_SELECTOR)) {
				currentState = 'clickable';
			} else if (isTextHit(target, x, y)) {
				currentState = 'text';
			} else {
				currentState = 'default';
			}
			updateCursorClasses();
		};

		const initCursor = () => {
			ensureCursor();
			updateCursorClasses();

			if (!rafId) {
				rafId = window.requestAnimationFrame(animateCursor);
			}
		};

		document.addEventListener('pointermove', (event) => {
			targetX = event.clientX;
			targetY = event.clientY;
			initCursor();
			setStateFromTarget(event.target, event.clientX, event.clientY);
		}, { passive: true });

		document.addEventListener('pointerdown', () => {
			isPressed = true;
			updateCursorClasses();
		}, { passive: true });

		document.addEventListener('pointerup', () => {
			isPressed = false;
			updateCursorClasses();
		}, { passive: true });

		document.addEventListener('pointerover', (event) => {
			setStateFromTarget(event.target, targetX, targetY);
		}, { passive: true });

		document.addEventListener('pointerleave', () => {
			if (!cursorEl) return;
			cursorEl.classList.remove('is-visible');
		});

		window.addEventListener('blur', () => {
			if (!cursorEl) return;
			cursorEl.classList.remove('is-visible');
		});

		window.addEventListener('focus', () => {
			if (!cursorEl) return;
			cursorEl.classList.add('is-visible');
		});

		document.addEventListener('astro:after-swap', () => {
			initCursor();
		});

		initCursor();
	})();
</script>
{
	import.meta.env.PROD && cfWebAnalyticsToken && (
		<script
			is:inline
			defer
			src="https://static.cloudflareinsights.com/beacon.min.js"
			data-cf-beacon={`{"token":"${cfWebAnalyticsToken}"}`}
		></script>
	)
}
