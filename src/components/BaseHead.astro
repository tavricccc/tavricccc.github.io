---
/*
 * Shared document head for every route.
 * Centralizing this keeps metadata/base-path behavior consistent across environments.
 */
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import type { ImageMetadata } from 'astro';
import { SITE_TITLE } from '../consts';

interface Props {
	// Human-readable page title used by document title and social metadata.
	title: string;
	// Summary used by search/social cards and meta description.
	description: string;
	// Optional social preview image; falls back to the branded OG card.
	image?: ImageMetadata | string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image } = Astro.props;
const BASE = import.meta.env.BASE_URL;
// Branded share card (1200x630) is the default for Discord/Twitter/OG previews.
const usesDefaultOgImage = !image;
const ogImagePath = typeof image === 'string' ? image : image?.src ?? `${BASE}image/og-default.png`;
const ogImageURL = new URL(ogImagePath, Astro.url);
const cfWebAnalyticsToken = import.meta.env.PUBLIC_CF_WEB_ANALYTICS_TOKEN;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<!-- Keep View Transitions globally enabled so only targeted links/routes opt out when needed. -->
<ClientRouter />
<!-- Favicon set generated from the original avatar (scripts/generate-brand-assets.mjs). -->
<link rel="icon" type="image/x-icon" href={`${BASE}image/favicon.ico`} />
<link rel="shortcut icon" href={`${BASE}image/favicon.ico`} />
<link rel="icon" type="image/png" sizes="32x32" href={`${BASE}image/favicon-32.png`} />
<link rel="icon" type="image/svg+xml" href={`${BASE}favicon.svg`} />
<link rel="apple-touch-icon" sizes="180x180" href={`${BASE}image/apple-touch-icon.png`} />
<link rel="sitemap" href={`${BASE}sitemap-index.xml`} />
<meta name="generator" content={Astro.generator} />

<!-- Font preconnect -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<style is:inline>
	{`
		@font-face {
			font-family: "Alibaba PuHuiTi";
			src: url('${BASE}fonts/AlibabaPuHuiTi-3-55-RegularL3.woff2') format('woff2');
			font-weight: 400;
			font-style: normal;
			font-display: swap;
		}
		@font-face {
			font-family: "Alibaba PuHuiTi";
			src: url('${BASE}fonts/AlibabaPuHuiTi-3-75-SemiBold.woff2') format('woff2');
			font-weight: 600;
			font-style: normal;
			font-display: swap;
		}
	`}
</style>
<!-- UI/body fonts prioritize immediate paint to reduce perceived loading delay. -->
<link
	rel="stylesheet"
	href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Noto+Serif+SC:wght@400;600&display=swap"
/>
<!-- Brand wordmark face, subset to the exact glyphs of "Dan's Blog" (~few KB). -->
<link
	rel="stylesheet"
	href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&text=Dan%27s%20Blog%E2%80%99&display=swap"
/>
<!-- Code font is optional to avoid post-paint metric swaps on large code blocks. -->
<link
	rel="stylesheet"
	href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=optional"
/>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="google-site-verification" content="c9eLQFflOQPGAa5ykLn2PnyXDt5rup4VJNQe3P8hW7Y" />

<!-- Open Graph / Facebook / Discord -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL} />
{usesDefaultOgImage && <meta property="og:image:width" content="1200" />}
{usesDefaultOgImage && <meta property="og:image:height" content="630" />}
{usesDefaultOgImage && <meta property="og:image:alt" content="Dan's Blog — Research · Engineering · Notes" />}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImageURL} />

<!-- Browser chrome tinting; kept in sync with the user-chosen theme by script. -->
<meta name="theme-color" content="#fafafa" />

<script is:inline>
	(() => {
		// Apply theme before hydration to avoid light/dark flash during initial paint.
		const storageKey = 'theme';
		const root = document.documentElement;
		const stored = localStorage.getItem(storageKey);
		const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
		const theme = stored === 'dark' || stored === 'light' ? stored : systemPrefersDark ? 'dark' : 'light';
		root.classList.toggle('dark', theme === 'dark');
		root.dataset.theme = theme;

		// Browser chrome color must follow the site theme (which can differ from
		// the OS preference), so it is synced here and on every toggle.
		window.__syncThemeColor = (isDark) => {
			const meta = document.querySelector('meta[name="theme-color"]');
			if (meta) meta.setAttribute('content', isDark ? '#09090b' : '#fafafa');
		};
		window.__syncThemeColor(theme === 'dark');
	})();
</script>
<script is:inline>
	(() => {
		// Run once per browsing session: re-executing would stack a second
		// MutationObserver and duplicate pointer listeners on document.
		if (window.__cursorScriptInit) return;
		window.__cursorScriptInit = true;

		const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		const supportsFinePointer = window.matchMedia('(pointer: fine)').matches;
		if (prefersReducedMotion || !supportsFinePointer) return;

		let cursorEl = null;
		let currentX = window.innerWidth / 2;
		let currentY = window.innerHeight / 2;
		let targetX = currentX;
		let targetY = currentY;
		let currentState = 'default';
		let isPressed = false;
		let hasPointerPosition = false;

		const TEXT_SELECTOR = [
			'p',
			'span',
			'strong',
			'em',
			'blockquote',
			'li',
			'h1',
			'h2',
			'h3',
			'h4',
			'h5',
			'h6',
			'figcaption',
			'td',
			'th',
			'summary',
			'label',
		].join(',');

		const CLICKABLE_SELECTOR = [
			'a',
			'button',
			'summary',
			'label',
			'input',
			'textarea',
			'select',
			'[role="button"]',
			'[role="tab"]',
			'.apple-float-chip',
			'.icon-button',
		].join(',');

		const applyCursorSuppression = () => {
			if (!document.documentElement.classList.contains('has-custom-cursor')) {
				document.documentElement.classList.add('has-custom-cursor');
			}
			if (document.documentElement.style.cursor !== 'none') {
				document.documentElement.style.cursor = 'none';
			}
			if (document.body && document.body.style.cursor !== 'none') {
				document.body.style.cursor = 'none';
			}
		};

		const ensureCursor = () => {
			if (cursorEl?.isConnected) return cursorEl;
			cursorEl = document.createElement('div');
			cursorEl.className = 'app-cursor';
			const target = document.body || document.documentElement;
			target.appendChild(cursorEl);
			applyCursorSuppression();
			return cursorEl;
		};

		const renderCursor = () => {
			const el = ensureCursor();
			el.style.transform = `translate3d(${currentX}px, ${currentY}px, 0) translate(-50%, -50%)`;
		};

		const updateCursorClasses = () => {
			const el = ensureCursor();
			el.classList.toggle('is-visible', hasPointerPosition);
			el.classList.toggle('is-clickable', currentState === 'clickable');
			el.classList.toggle('is-text', currentState === 'text');
			el.classList.toggle('is-pressed', isPressed);
		};

		const isPointInsideRect = (x, y, rect) => {
			return x >= rect.left && x <= rect.right && y >= rect.top && y <= rect.bottom;
		};

		const isTextHit = (target, x, y) => {
			if (!(target instanceof Element)) return false;

			const textElement = target.closest(TEXT_SELECTOR);
			if (!textElement) return false;

			const caretRange = document.caretRangeFromPoint?.(x, y);
			if (caretRange?.startContainer) {
				const node = caretRange.startContainer;
				const parentElement = node.nodeType === Node.TEXT_NODE ? node.parentElement : node;
				if (parentElement instanceof Element && parentElement.closest(TEXT_SELECTOR)) {
					return true;
				}
			}

			if (document.caretPositionFromPoint) {
				const caretPosition = document.caretPositionFromPoint(x, y);
				const node = caretPosition?.offsetNode;
				const parentElement = node?.nodeType === Node.TEXT_NODE ? node.parentElement : node;
				if (parentElement instanceof Element && parentElement.closest(TEXT_SELECTOR)) {
					return true;
				}
			}

			const range = document.createRange();
			const walker = document.createTreeWalker(textElement, NodeFilter.SHOW_TEXT, {
				acceptNode(node) {
					return node.textContent?.trim() ? NodeFilter.FILTER_ACCEPT : NodeFilter.FILTER_REJECT;
				},
			});

			let textNode = walker.nextNode();
			while (textNode) {
				range.selectNodeContents(textNode);
				const rects = range.getClientRects();
				for (const rect of rects) {
					if (isPointInsideRect(x, y, rect)) {
						return true;
					}
				}
				textNode = walker.nextNode();
			}

			return false;
		};

		const setStateFromTarget = (target, x = targetX, y = targetY) => {
			if (!(target instanceof Element)) {
				currentState = 'default';
				updateCursorClasses();
				return;
			}

			if (target.closest(CLICKABLE_SELECTOR)) {
				currentState = 'clickable';
			} else if (isTextHit(target, x, y)) {
				currentState = 'text';
			} else {
				currentState = 'default';
			}
			updateCursorClasses();
		};

		const initCursor = () => {
			applyCursorSuppression();
			ensureCursor();
			updateCursorClasses();
			renderCursor();
		};

		document.addEventListener('pointermove', (event) => {
			if (event.pointerType && event.pointerType !== 'mouse') return;
			targetX = event.clientX;
			targetY = event.clientY;
			currentX = targetX;
			currentY = targetY;
			hasPointerPosition = true;
			initCursor();
			setStateFromTarget(event.target, event.clientX, event.clientY);
		}, { passive: true });

		document.addEventListener('pointerdown', (event) => {
			if (event.pointerType && event.pointerType !== 'mouse') return;
			isPressed = true;
			updateCursorClasses();
		}, { passive: true });

		document.addEventListener('pointerup', (event) => {
			if (event.pointerType && event.pointerType !== 'mouse') return;
			isPressed = false;
			updateCursorClasses();
		}, { passive: true });

		document.addEventListener('pointerover', (event) => {
			if (event.pointerType && event.pointerType !== 'mouse') return;
			setStateFromTarget(event.target, targetX, targetY);
		}, { passive: true });

		document.addEventListener('pointerleave', () => {
			if (!cursorEl) return;
			hasPointerPosition = false;
			cursorEl.classList.remove('is-visible');
		});

		window.addEventListener('blur', () => {
			if (!cursorEl) return;
			hasPointerPosition = false;
			cursorEl.classList.remove('is-visible');
		});

		window.addEventListener('focus', () => {
			if (!cursorEl) return;
			applyCursorSuppression();
			updateCursorClasses();
		});

		document.addEventListener('astro:after-swap', () => {
			applyCursorSuppression();
			requestAnimationFrame(applyCursorSuppression);
			initCursor();
		});

		document.addEventListener('astro:page-load', () => {
			applyCursorSuppression();
			requestAnimationFrame(applyCursorSuppression);
			initCursor();
		});

		document.addEventListener('visibilitychange', () => {
			if (document.visibilityState === 'visible') {
				applyCursorSuppression();
			}
		});

		const cursorObserver = new MutationObserver(() => {
			applyCursorSuppression();
		});

		cursorObserver.observe(document.documentElement, {
			attributes: true,
			attributeFilter: ['class', 'style'],
		});

		if (document.body) {
			cursorObserver.observe(document.body, {
				attributes: true,
				attributeFilter: ['style', 'class'],
			});
		} else {
			document.addEventListener('DOMContentLoaded', () => {
				applyCursorSuppression();
				if (!document.body) return;
				cursorObserver.observe(document.body, {
					attributes: true,
					attributeFilter: ['style', 'class'],
				});
			}, { once: true });
		}

		initCursor();
	})();
</script>
<script is:inline>
	(() => {
		/*
		 * Polish-layer interactions shared by every page:
		 * 1. scroll-triggered reveal for [data-reveal] elements
		 * 2. pointer-tracking spotlight position for .card-spotlight elements
		 * Both are progressive enhancements: without JS (or with reduced motion)
		 * content stays fully visible and cards simply skip the glow.
		 * Guarded so re-execution never duplicates document-level listeners.
		 */
		if (window.__polishScriptInit) return;
		window.__polishScriptInit = true;

		const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		if (!reducedMotion && 'IntersectionObserver' in window) {
			document.documentElement.classList.add('js-reveal');

			let observer = null;
			const ensureObserver = () => {
				if (observer) return observer;
				observer = new IntersectionObserver(
					(entries) => {
						for (const entry of entries) {
							if (!entry.isIntersecting) continue;
							entry.target.classList.add('revealed');
							observer.unobserve(entry.target);
						}
					},
					{ rootMargin: '0px 0px -7% 0px', threshold: 0.06 }
				);
				return observer;
			};

			const scanReveals = () => {
				// Route swaps can reset the <html> class attribute, so re-assert before scanning.
				document.documentElement.classList.add('js-reveal');
				const io = ensureObserver();
				const vh = window.innerHeight || document.documentElement.clientHeight || 0;
				document.querySelectorAll('[data-reveal]:not(.revealed)').forEach((el) => {
					// Reveal anything already in (or above) the viewport right away, so
					// content never stays hidden if the IntersectionObserver callback is
					// throttled (e.g. background tabs). Below-the-fold elements still
					// animate in on scroll via the observer.
					const rect = el.getBoundingClientRect();
					if (rect.top < vh * 0.95 && rect.bottom > -1) {
						el.classList.add('revealed');
					} else {
						io.observe(el);
					}
				});
			};

			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', scanReveals, { once: true });
			} else {
				scanReveals();
			}
			document.addEventListener('astro:page-load', scanReveals);
			document.addEventListener('astro:after-swap', scanReveals);
		}

		// Directional page transitions: slide left/right based on nav order.
		// The data attribute is consumed by ::view-transition CSS in global.css.
		{
			const NAV_ORDER = { '': 0, blog: 1, tags: 2, links: 3, about: 4 };
			const segmentFor = (url) => {
				const parts = url.pathname.split('/').filter(Boolean).filter((p) => p !== 'DansBlog');
				return parts[0] || '';
			};

			document.addEventListener('astro:before-preparation', (event) => {
				const root = document.documentElement;
				delete root.dataset.navDir;
				try {
					const fromIdx = NAV_ORDER[segmentFor(event.from)];
					const toIdx = NAV_ORDER[segmentFor(event.to)];
					if (fromIdx === undefined || toIdx === undefined || fromIdx === toIdx) return;
					root.dataset.navDir = toIdx > fromIdx ? 'forward' : 'back';
				} catch {}
			});
		}

		if (window.matchMedia('(pointer: fine)').matches) {
			let rafId = 0;
			let lastEvent = null;

			const applySpotlight = () => {
				rafId = 0;
				const event = lastEvent;
				if (!event) return;
				const card = event.target instanceof Element ? event.target.closest('.card-spotlight') : null;
				if (!card) return;
				const rect = card.getBoundingClientRect();
				card.style.setProperty('--spot-x', `${event.clientX - rect.left}px`);
				card.style.setProperty('--spot-y', `${event.clientY - rect.top}px`);
			};

			document.addEventListener(
				'pointermove',
				(event) => {
					if (event.pointerType && event.pointerType !== 'mouse') return;
					lastEvent = event;
					if (!rafId) rafId = requestAnimationFrame(applySpotlight);
				},
				{ passive: true }
			);
		}
	})();
</script>
{
	import.meta.env.PROD && cfWebAnalyticsToken && (
		<script
			is:inline
			defer
			src="https://static.cloudflareinsights.com/beacon.min.js"
			data-cf-beacon={`{"token":"${cfWebAnalyticsToken}"}`}
		></script>
	)
}
